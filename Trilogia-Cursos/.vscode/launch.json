{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Proyecto_Final (ASP.NET Core)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/Proyecto_Final/bin/Debug/net9.0/Proyecto_Final.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Proyecto_Final",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": { "ASPNETCORE_ENVIRONMENT": "Development" }
    }
  ]
}