@using Proyecto_Final.Models.Admin
@model IEnumerable<ComodatoListItemViewModel>
@{
    ViewData["Title"] = "Comodatos";
    var estado = ViewBag.Estado as string;
    var buscar = ViewBag.Buscar as string;
    string EstadoBadge(string e) => e switch { "Activo" => "info", "Devuelto" => "success", _ => "warning" };
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="mb-2">Comodatos de equipos</h2>
                    <p class="mb-0">Trazabilidad de neveras y exhibidores prestados a clientes: quién los tiene y desde cuándo.</p>
                </div>
                <div class="mt-2 mt-md-0">
                    <a asp-action="Profitability" class="btn btn-light border mr-2"><i class="fa fa-chart-pie mr-2 text-primary"></i>Rentabilidad</a>
                    <a asp-action="Assign" class="btn btn-primary"><i class="fa fa-plus mr-2"></i>Asignar comodato</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-filter-bar">
                <form asp-action="Index" method="get" class="form-inline">
                    <input type="text" name="buscar" value="@buscar" class="form-control mr-2 mb-2" placeholder="Código, activo o cliente" />
                    <select name="estado" class="form-control mr-2 mb-2">
                        <option value="">Todos los estados</option>
                        <option value="Activo" selected="@(estado == "Activo")">Activo</option>
                        <option value="Devuelto" selected="@(estado == "Devuelto")">Devuelto</option>
                        <option value="Retirado" selected="@(estado == "Retirado")">Retirado</option>
                    </select>
                    <button type="submit" class="btn btn-primary mr-2 mb-2"><i class="fa fa-search mr-2"></i>Buscar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary mb-2"><i class="fa fa-eraser mr-2"></i>Limpiar</a>
                </form>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="p-4 border-bottom d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-0">Equipos en comodato</h5>
                    <span class="text-muted">Total: @(Model?.Count() ?? 0)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="thead-light">
                            <tr>
                                <th>Código</th><th>Activo</th><th>Cliente</th><th>Ubicación</th>
                                <th class="text-center">Desde</th><th class="text-center">Días</th>
                                <th class="text-center">Estado</th><th class="text-center">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr><td colspan="8" class="text-center text-muted py-4">No hay comodatos registrados.</td></tr>
                            }
                            else
                            {
                                @foreach (var c in Model)
                                {
                                    <tr>
                                        <td class="font-weight-bold">@c.CodigoActivo</td>
                                        <td>@c.ActivoNombre <span class="text-muted small">(@c.ActivoTipo)</span></td>
                                        <td>@c.ClienteNombre</td>
                                        <td>@(string.IsNullOrWhiteSpace(c.Ubicacion) ? "—" : c.Ubicacion)</td>
                                        <td class="text-center">@c.FechaAsignacion.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@c.DiasEnComodato</td>
                                        <td class="text-center"><span class="admin-badge-soft @EstadoBadge(c.Estado)">@c.Estado</span></td>
                                        <td class="text-center">
                                            @if (c.Estado == "Activo")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-toggle="collapse" data-target="#ret-@c.ComodatoId">
                                                    <i class="fa fa-undo mr-1"></i>Devolver
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                    @if (c.Estado == "Activo")
                                    {
                                        <tr class="collapse" id="ret-@c.ComodatoId">
                                            <td colspan="8" class="bg-light">
                                                <form asp-action="Return" method="post" class="form-inline flex-wrap"
                                                      data-s3-confirm="¿Cerrar este comodato? El activo cambiará de estado según el destino."
                                                      data-s3-confirm-title="Devolver / retirar equipo"
                                                      data-s3-confirm-type="warning"
                                                      data-s3-confirm-ok="Sí, registrar"
                                                      data-s3-confirm-cancel="Cancelar">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="ComodatoId" value="@c.ComodatoId" />
                                                    <label class="mr-2 mb-2">Destino</label>
                                                    <select name="Destino" class="form-control mr-2 mb-2">
                                                        <option value="Inventario">Reingresar a inventario</option>
                                                        <option value="Mantenimiento">Enviar a mantenimiento</option>
                                                    </select>
                                                    <input name="CondicionDevolucion" class="form-control mr-2 mb-2" placeholder="Condición del equipo (opcional)" style="min-width:260px" />
                                                    <button type="submit" class="btn btn-primary mb-2"><i class="fa fa-check mr-1"></i>Registrar devolución</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
