@model Proyecto_Final.Models.Admin.SellerOrderCreateViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Venta móvil";

    var clientesCatalogoJson = JsonSerializer.Serialize(Model.Clientes.Select(cliente => new
    {
        usuarioId = cliente.UsuarioId,
        nombreCompleto = cliente.NombreCompleto,
        correo = cliente.Correo,
        telefono = cliente.Telefono,
        direccion = cliente.Direccion,
        displayText = cliente.DisplayText
    }));

    var productosCatalogoJson = JsonSerializer.Serialize(Model.Productos.Select(producto => new
    {
        productoId = producto.ProductoId,
        nombre = producto.Nombre,
        categoria = producto.Categoria,
        precio = producto.Precio,
        stock = producto.Stock
    }));
}

@section Styles {
    <style>
        .seller-mobile-summary {
            position: sticky;
            bottom: 0;
            z-index: 20;
            border-radius: 18px 18px 0 0;
            box-shadow: 0 -8px 24px rgba(0,0,0,.12);
        }

        .seller-product-card {
            border: 1px solid #e8e8e8;
            border-radius: 16px;
            padding: 14px;
            background: #fff;
            height: 100%;
            box-shadow: 0 8px 20px rgba(17,17,17,.04);
        }

        .seller-product-card__title {
            min-height: 42px;
            font-weight: 700;
            color: #1b1b1b;
        }

        .seller-qty {
            max-width: 110px;
            margin-left: auto;
        }

        .offline-status-card {
            border: 1px solid rgba(255,255,255,.18);
            border-radius: 18px;
            padding: 16px;
            background: linear-gradient(135deg, #171717, #2b2b2b);
            color: #fff;
            box-shadow: 0 12px 28px rgba(0,0,0,.12);
        }

        .offline-status-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border-radius: 999px;
            padding: 7px 12px;
            font-weight: 700;
            background: rgba(255,255,255,.12);
        }

        .offline-status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #28a745;
            box-shadow: 0 0 0 4px rgba(40,167,69,.18);
        }

        .offline-status-pill.is-offline .offline-status-dot {
            background: #ffc107;
            box-shadow: 0 0 0 4px rgba(255,193,7,.20);
        }

        .pending-orders-panel {
            display: none;
        }

        .pending-orders-panel.is-visible {
            display: block;
        }

        .offline-order-card {
            border: 1px solid #ececec;
            border-radius: 14px;
            padding: 12px;
            background: #fff;
            margin-bottom: 10px;
        }

        .offline-order-card small {
            display: block;
        }

        @@media (max-width: 767.98px) {
            .seller-qty {
                max-width: 100%;
                margin-left: 0;
            }
        }
    </style>
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div>
                    <h2 class="mb-1">Venta móvil</h2>
                    <p class="mb-0">Registrar pedidos de clientes desde celular o tablet, incluso si se pierde la conexión.</p>
                </div>
                <a asp-controller="OrdersAdmin" asp-action="Index" class="btn btn-outline-light mt-3 mt-md-0">
                    <i class="fa fa-clipboard-list mr-1"></i> Ver pedidos
                </a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 mb-3">
        <div class="col-12">
            <div class="offline-status-card">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center" style="gap:14px;">
                    <div>
                        <span id="connectionStatus" class="offline-status-pill">
                            <span class="offline-status-dot"></span>
                            <span id="connectionStatusText">En línea</span>
                        </span>
                        <h5 class="mt-3 mb-1 text-white">Modo pedidos offline</h5>
                        <p class="mb-0 text-white-50">
                            Si se pierde internet, el pedido se guarda en este navegador y luego se sincroniza al volver la conexión.
                        </p>
                    </div>
                    <div class="d-flex flex-column flex-md-row align-items-md-center" style="gap:10px;">
                        <span class="badge badge-warning p-2">Pendientes: <span id="pendingOrdersCount">0</span></span>
                        <button type="button" id="togglePendingOrders" class="btn btn-outline-light">
                            <i class="fa fa-list mr-1"></i> Ver pendientes
                        </button>
                        <button type="button" id="syncPendingOrders" class="btn btn-primary">
                            <i class="fa fa-sync mr-1"></i> Sincronizar ahora
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        <div class="col-12">
            <div id="sellerOfflineMessage" class="alert d-none" role="alert"></div>
            <div id="pendingOrdersPanel" class="admin-card pending-orders-panel mb-3">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3" style="gap:10px;">
                    <div>
                        <h5 class="mb-1">Pedidos guardados en este navegador</h5>
                        <p class="text-muted mb-0">Los pedidos con error se pueden reintentar cuando haya conexión.</p>
                    </div>
                    <button type="button" id="clearSyncedOrders" class="btn btn-outline-secondary btn-sm">
                        Limpiar sincronizados
                    </button>
                </div>
                <div id="pendingOrdersList"></div>
            </div>
        </div>
    </div>

    <form asp-controller="SellerOrders" asp-action="Create" method="post" id="sellerOrderForm">
        @Html.AntiForgeryToken()

        <div class="row px-xl-5">
            <div class="col-12">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
            </div>
        </div>

        <div class="row px-xl-5">
            <div class="col-lg-4 mb-4">
                <div class="admin-card h-100">
                    <h5 class="mb-3">Cliente y entrega</h5>

                    <div class="form-group">
                        <label asp-for="ClienteUsuarioId" class="font-weight-bold"></label>
                        <select asp-for="ClienteUsuarioId" class="form-control">
                            <option value="0">Seleccione un cliente...</option>
                            @foreach (var cliente in Model.Clientes)
                            {
                                <option value="@cliente.UsuarioId" data-address="@cliente.Direccion">
                                    @cliente.DisplayText
                                </option>
                            }
                        </select>
                        <span asp-validation-for="ClienteUsuarioId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="IdentificacionCliente" class="font-weight-bold"></label>
                        <input asp-for="IdentificacionCliente" class="form-control" placeholder="Cédula física o jurídica" />
                        <span asp-validation-for="IdentificacionCliente" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="TipoEntrega" class="font-weight-bold"></label>
                        <select asp-for="TipoEntrega" class="form-control">
                            <option>Entrega por vendedor</option>
                            <option>Retiro en local</option>
                            <option>Envío a domicilio</option>
                        </select>
                        <span asp-validation-for="TipoEntrega" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="DireccionEntrega" class="font-weight-bold"></label>
                        <textarea asp-for="DireccionEntrega" class="form-control" rows="4" placeholder="Dirección, señas o punto de entrega"></textarea>
                        <span asp-validation-for="DireccionEntrega" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-0">
                        <label asp-for="Observaciones" class="font-weight-bold"></label>
                        <textarea asp-for="Observaciones" class="form-control" rows="3" placeholder="Notas para despacho o facturación"></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="col-lg-8 mb-4">
                <div class="admin-card mb-3">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center" style="gap:12px;">
                        <div>
                            <h5 class="mb-1">Productos disponibles</h5>
                            <p class="text-muted mb-0">Digite cantidades. Solo se guardan productos con cantidad mayor a cero.</p>
                        </div>
                        <input type="text" id="productSearch" class="form-control" style="max-width:320px;" placeholder="Buscar producto o categoría..." />
                    </div>
                </div>

                <div class="row" id="productsGrid">
                    @for (var i = 0; i < Model.Productos.Count; i++)
                    {
                        <div class="col-md-6 col-xl-4 mb-3 seller-product-item"
                             data-product-id="@Model.Productos[i].ProductoId"
                             data-name="@Model.Productos[i].Nombre.ToLower()"
                             data-category="@Model.Productos[i].Categoria.ToLower()"
                             data-display-name="@Model.Productos[i].Nombre"
                             data-display-category="@Model.Productos[i].Categoria"
                             data-price="@Model.Productos[i].Precio.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                             data-stock="@Model.Productos[i].Stock">
                            <div class="seller-product-card">
                                <input type="hidden" asp-for="Productos[i].ProductoId" />
                                <input type="hidden" asp-for="Productos[i].Nombre" />
                                <input type="hidden" asp-for="Productos[i].Categoria" />
                                <input type="hidden" asp-for="Productos[i].Precio" />
                                <input type="hidden" asp-for="Productos[i].Stock" />

                                <div class="seller-product-card__title">@Model.Productos[i].Nombre</div>
                                <div class="text-muted small mb-2">@Model.Productos[i].Categoria</div>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="font-weight-bold">₡@Model.Productos[i].Precio.ToString("N2")</span>
                                    <span class="badge badge-light">Stock: @Model.Productos[i].Stock</span>
                                </div>

                                <label class="small text-muted mb-1">Cantidad</label>
                                <input asp-for="Productos[i].Cantidad"
                                       type="number"
                                       min="0"
                                       max="@Model.Productos[i].Stock"
                                       class="form-control seller-quantity"
                                       data-price="@Model.Productos[i].Precio.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                       data-stock="@Model.Productos[i].Stock" />
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="container-fluid px-xl-5 seller-mobile-summary">
            <div class="admin-card d-flex flex-column flex-md-row justify-content-between align-items-md-center" style="gap:12px;">
                <div>
                    <strong>Total seleccionado:</strong>
                    <span id="selectedItems">0</span> producto(s) / <span id="selectedUnits">0</span> unidad(es)
                    <div class="text-muted small">Total estimado: <strong id="selectedTotal">₡0,00</strong></div>
                </div>
                <div class="d-flex flex-column flex-md-row" style="gap:10px;">
                    <button type="button" id="saveOfflineOrder" class="btn btn-outline-secondary btn-lg">
                        <i class="fa fa-cloud-download-alt mr-1"></i> Guardar sin conexión
                    </button>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fa fa-save mr-1"></i> Registrar pedido
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const search = document.getElementById('productSearch');
            const items = Array.from(document.querySelectorAll('.seller-product-item'));
            const quantities = Array.from(document.querySelectorAll('.seller-quantity'));
            const selectedItems = document.getElementById('selectedItems');
            const selectedUnits = document.getElementById('selectedUnits');
            const selectedTotal = document.getElementById('selectedTotal');
            const clientSelect = document.getElementById('ClienteUsuarioId');
            const address = document.getElementById('DireccionEntrega');
            const form = document.getElementById('sellerOrderForm');
            const saveOfflineButton = document.getElementById('saveOfflineOrder');
            const connectionStatus = document.getElementById('connectionStatus');
            const connectionStatusText = document.getElementById('connectionStatusText');
            const pendingOrdersCount = document.getElementById('pendingOrdersCount');
            const togglePendingOrders = document.getElementById('togglePendingOrders');
            const syncPendingOrdersButton = document.getElementById('syncPendingOrders');
            const clearSyncedOrdersButton = document.getElementById('clearSyncedOrders');
            const pendingOrdersPanel = document.getElementById('pendingOrdersPanel');
            const pendingOrdersList = document.getElementById('pendingOrdersList');
            const offlineMessage = document.getElementById('sellerOfflineMessage');
            const storageKey = 'distribuidorajj_seller_offline_orders_v1';
            const catalogKey = 'distribuidorajj_seller_catalog_v1';
            const syncUrl = '@Url.Action("SyncOffline", "SellerOrders")';
            const catalog = {
                clientes: @Html.Raw(clientesCatalogoJson),
                productos: @Html.Raw(productosCatalogoJson)
            };
            let isSyncing = false;

            function formatCurrency(value) {
                return '₡' + value.toLocaleString('es-CR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function createGuid() {
                if (window.crypto && typeof window.crypto.randomUUID === 'function') {
                    return window.crypto.randomUUID();
                }

                return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (char) {
                    const random = Math.random() * 16 | 0;
                    const value = char === 'x' ? random : (random & 0x3 | 0x8);
                    return value.toString(16);
                });
            }

            function getToken() {
                const tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
                return tokenInput ? tokenInput.value : '';
            }

            function showMessage(type, message) {
                offlineMessage.className = 'alert alert-' + type;
                offlineMessage.textContent = message;
                offlineMessage.classList.remove('d-none');
            }

            function hideMessage() {
                offlineMessage.classList.add('d-none');
                offlineMessage.textContent = '';
            }

            function loadOrders() {
                try {
                    const raw = localStorage.getItem(storageKey);
                    return raw ? JSON.parse(raw) : [];
                } catch (error) {
                    return [];
                }
            }

            function saveOrders(orders) {
                localStorage.setItem(storageKey, JSON.stringify(orders));
                renderPendingOrders();
            }

            function cacheCatalog() {
                localStorage.setItem(catalogKey, JSON.stringify({
                    actualizadoEn: new Date().toISOString(),
                    clientes: catalog.clientes,
                    productos: catalog.productos
                }));
            }

            function updateConnectionStatus() {
                const online = navigator.onLine;
                connectionStatus.classList.toggle('is-offline', !online);
                connectionStatusText.textContent = online ? 'En línea' : 'Sin conexión';
                saveOfflineButton.classList.toggle('btn-warning', !online);
                saveOfflineButton.classList.toggle('btn-outline-secondary', online);

                if (!online) {
                    showMessage('warning', 'Sin conexión. El pedido se guardará localmente y se sincronizará cuando vuelva internet.');
                }
            }

            function updateSummary() {
                let productCount = 0;
                let unitCount = 0;
                let total = 0;

                quantities.forEach(input => {
                    const qty = parseInt(input.value || '0', 10);
                    const price = parseFloat(input.dataset.price || '0');
                    if (qty > 0) {
                        productCount += 1;
                        unitCount += qty;
                        total += qty * price;
                    }
                });

                selectedItems.textContent = productCount;
                selectedUnits.textContent = unitCount;
                selectedTotal.textContent = formatCurrency(total);
            }

            function filterProducts() {
                const term = (search.value || '').trim().toLowerCase();
                items.forEach(item => {
                    const match = !term || item.dataset.name.includes(term) || item.dataset.category.includes(term);
                    item.style.display = match ? '' : 'none';
                });
            }

            function buildOrderFromForm() {
                const clienteUsuarioId = parseInt(clientSelect.value || '0', 10);
                const selectedClient = clientSelect.options[clientSelect.selectedIndex];
                const tipoEntrega = (document.getElementById('TipoEntrega').value || '').trim();
                const direccionEntrega = (document.getElementById('DireccionEntrega').value || '').trim();
                const identificacionCliente = (document.getElementById('IdentificacionCliente').value || '').trim();
                const observaciones = (document.getElementById('Observaciones').value || '').trim();
                const productos = [];
                const errors = [];
                let total = 0;
                let totalItems = 0;

                if (clienteUsuarioId <= 0) {
                    errors.push('Debe seleccionar un cliente.');
                }

                if (!tipoEntrega) {
                    errors.push('Debe seleccionar el tipo de entrega.');
                }

                if (!direccionEntrega) {
                    errors.push('Debe indicar la dirección de entrega.');
                }

                quantities.forEach(input => {
                    const qty = parseInt(input.value || '0', 10);
                    if (qty <= 0) {
                        return;
                    }

                    const item = input.closest('.seller-product-item');
                    const stock = parseInt(item.dataset.stock || '0', 10);
                    const price = parseFloat(item.dataset.price || '0');

                    if (qty > stock) {
                        errors.push('La cantidad de ' + item.dataset.displayName + ' supera el stock disponible.');
                    }

                    productos.push({
                        productoId: parseInt(item.dataset.productId || '0', 10),
                        nombre: item.dataset.displayName || 'Producto',
                        categoria: item.dataset.displayCategory || '',
                        cantidad: qty,
                        precio: price,
                        stock: stock
                    });

                    totalItems += qty;
                    total += qty * price;
                });

                if (productos.length === 0) {
                    errors.push('Debe seleccionar al menos un producto.');
                }

                return {
                    isValid: errors.length === 0,
                    errors: errors,
                    order: {
                        pedidoOfflineGuid: createGuid(),
                        clienteUsuarioId: clienteUsuarioId,
                        clienteNombre: selectedClient ? selectedClient.textContent.trim() : '',
                        tipoEntrega: tipoEntrega,
                        direccionEntrega: direccionEntrega,
                        identificacionCliente: identificacionCliente,
                        observaciones: observaciones,
                        productos: productos,
                        total: total,
                        totalItems: totalItems,
                        estadoOffline: 'Pendiente',
                        mensajeError: '',
                        pedidoId: null,
                        redirectUrl: '',
                        creadoEn: new Date().toISOString(),
                        actualizadoEn: new Date().toISOString()
                    }
                };
            }

            function clearCurrentOrderForm() {
                form.reset();
                quantities.forEach(input => input.value = '0');
                updateSummary();
            }

            function saveCurrentOrderOffline() {
                const result = buildOrderFromForm();

                if (!result.isValid) {
                    showMessage('danger', result.errors[0]);
                    return false;
                }

                const orders = loadOrders();
                orders.push(result.order);
                saveOrders(orders);
                clearCurrentOrderForm();
                pendingOrdersPanel.classList.add('is-visible');
                showMessage('success', 'Pedido guardado sin conexión. Quedó pendiente para sincronizar.');
                return true;
            }

            function getStatusBadgeClass(status) {
                switch (status) {
                    case 'Sincronizado': return 'badge-success';
                    case 'Sincronizando': return 'badge-info';
                    case 'Error': return 'badge-danger';
                    default: return 'badge-warning';
                }
            }

            function renderPendingOrders() {
                const orders = loadOrders();
                const pendingCount = orders.filter(order => order.estadoOffline !== 'Sincronizado').length;
                pendingOrdersCount.textContent = pendingCount;

                if (orders.length === 0) {
                    pendingOrdersList.innerHTML = '<div class="text-muted">No hay pedidos offline guardados en este navegador.</div>';
                    return;
                }

                pendingOrdersList.innerHTML = orders.map(order => {
                    const productsText = order.productos.map(product => escapeHtml(product.nombre) + ' x' + product.cantidad).join(', ');
                    const createdAt = new Date(order.creadoEn).toLocaleString('es-CR');
                    const status = order.estadoOffline || 'Pendiente';
                    const badgeClass = getStatusBadgeClass(status);
                    const errorHtml = order.mensajeError ? '<small class="text-danger mt-1">' + escapeHtml(order.mensajeError) + '</small>' : '';
                    const detailLink = order.redirectUrl
                        ? '<a class="btn btn-sm btn-outline-primary" href="' + escapeHtml(order.redirectUrl) + '">Ver pedido</a>'
                        : '';

                    return '<div class="offline-order-card" data-guid="' + escapeHtml(order.pedidoOfflineGuid) + '">' +
                        '<div class="d-flex flex-column flex-md-row justify-content-between" style="gap:8px;">' +
                            '<div>' +
                                '<strong>' + escapeHtml(order.clienteNombre) + '</strong>' +
                                '<small class="text-muted">Guardado: ' + createdAt + '</small>' +
                                '<small class="text-muted">Productos: ' + productsText + '</small>' +
                                '<small class="text-muted">Total estimado: ' + formatCurrency(order.total || 0) + '</small>' +
                                errorHtml +
                            '</div>' +
                            '<div class="text-md-right">' +
                                '<span class="badge ' + badgeClass + ' mb-2">' + escapeHtml(status) + '</span>' +
                                '<div class="d-flex justify-content-md-end" style="gap:6px;">' +
                                    detailLink +
                                    '<button type="button" class="btn btn-sm btn-outline-danger" data-remove-offline="' + escapeHtml(order.pedidoOfflineGuid) + '">Eliminar</button>' +
                                '</div>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
                }).join('');
            }

            async function syncPendingOrders() {
                if (isSyncing) {
                    return;
                }

                if (!navigator.onLine) {
                    showMessage('warning', 'No hay conexión. Los pedidos seguirán guardados localmente.');
                    return;
                }

                const token = getToken();
                let orders = loadOrders();
                const candidates = orders.filter(order => order.estadoOffline !== 'Sincronizado');

                if (candidates.length === 0) {
                    showMessage('info', 'No hay pedidos pendientes para sincronizar.');
                    return;
                }

                isSyncing = true;
                syncPendingOrdersButton.disabled = true;
                showMessage('info', 'Sincronizando pedidos pendientes...');

                for (const candidate of candidates) {
                    orders = loadOrders();
                    const index = orders.findIndex(order => order.pedidoOfflineGuid === candidate.pedidoOfflineGuid);
                    if (index < 0) {
                        continue;
                    }

                    orders[index].estadoOffline = 'Sincronizando';
                    orders[index].mensajeError = '';
                    orders[index].actualizadoEn = new Date().toISOString();
                    saveOrders(orders);

                    try {
                        const response = await fetch(syncUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({
                                pedidoOfflineGuid: orders[index].pedidoOfflineGuid,
                                clienteUsuarioId: orders[index].clienteUsuarioId,
                                tipoEntrega: orders[index].tipoEntrega,
                                direccionEntrega: orders[index].direccionEntrega,
                                identificacionCliente: orders[index].identificacionCliente,
                                observaciones: orders[index].observaciones,
                                productos: orders[index].productos.map(product => ({
                                    productoId: product.productoId,
                                    cantidad: product.cantidad
                                }))
                            })
                        });

                        const data = await response.json();
                        const success = data.success === true || data.Success === true;
                        const message = data.message || data.Message || 'No fue posible sincronizar el pedido.';
                        const pedidoId = data.pedidoId || data.PedidoId || null;
                        const redirectUrl = data.redirectUrl || data.RedirectUrl || '';

                        orders = loadOrders();
                        const currentIndex = orders.findIndex(order => order.pedidoOfflineGuid === candidate.pedidoOfflineGuid);
                        if (currentIndex < 0) {
                            continue;
                        }

                        if (response.ok && success) {
                            orders[currentIndex].estadoOffline = 'Sincronizado';
                            orders[currentIndex].pedidoId = pedidoId;
                            orders[currentIndex].redirectUrl = redirectUrl;
                            orders[currentIndex].mensajeError = '';
                        } else {
                            orders[currentIndex].estadoOffline = 'Error';
                            orders[currentIndex].mensajeError = message;
                        }

                        orders[currentIndex].actualizadoEn = new Date().toISOString();
                        saveOrders(orders);
                    } catch (error) {
                        orders = loadOrders();
                        const currentIndex = orders.findIndex(order => order.pedidoOfflineGuid === candidate.pedidoOfflineGuid);
                        if (currentIndex >= 0) {
                            orders[currentIndex].estadoOffline = 'Error';
                            orders[currentIndex].mensajeError = 'Error de conexión al sincronizar. Intente nuevamente.';
                            orders[currentIndex].actualizadoEn = new Date().toISOString();
                            saveOrders(orders);
                        }
                    }
                }

                isSyncing = false;
                syncPendingOrdersButton.disabled = false;

                const remaining = loadOrders().filter(order => order.estadoOffline !== 'Sincronizado').length;
                if (remaining === 0) {
                    showMessage('success', 'Todos los pedidos offline fueron sincronizados correctamente.');
                } else {
                    showMessage('warning', 'Algunos pedidos no se pudieron sincronizar. Revise la lista de pendientes.');
                }
            }

            quantities.forEach(input => input.addEventListener('input', updateSummary));
            search.addEventListener('input', filterProducts);

            clientSelect.addEventListener('change', function () {
                const selected = clientSelect.options[clientSelect.selectedIndex];
                const savedAddress = selected ? selected.getAttribute('data-address') : '';
                if (savedAddress && !address.value.trim()) {
                    address.value = savedAddress;
                }
            });

            form.addEventListener('submit', function (event) {
                if (!navigator.onLine) {
                    event.preventDefault();
                    saveCurrentOrderOffline();
                }
            });

            saveOfflineButton.addEventListener('click', function () {
                saveCurrentOrderOffline();
            });

            togglePendingOrders.addEventListener('click', function () {
                pendingOrdersPanel.classList.toggle('is-visible');
            });

            syncPendingOrdersButton.addEventListener('click', syncPendingOrders);

            clearSyncedOrdersButton.addEventListener('click', function () {
                const orders = loadOrders().filter(order => order.estadoOffline !== 'Sincronizado');
                saveOrders(orders);
                showMessage('success', 'Pedidos sincronizados eliminados de la lista local.');
            });

            pendingOrdersList.addEventListener('click', function (event) {
                const button = event.target.closest('[data-remove-offline]');
                if (!button) {
                    return;
                }

                const guid = button.getAttribute('data-remove-offline');
                const orders = loadOrders().filter(order => order.pedidoOfflineGuid !== guid);
                saveOrders(orders);
                showMessage('success', 'Pedido offline eliminado de este navegador.');
            });

            window.addEventListener('online', function () {
                updateConnectionStatus();
                syncPendingOrders();
            });

            window.addEventListener('offline', updateConnectionStatus);

            cacheCatalog();
            updateSummary();
            updateConnectionStatus();
            renderPendingOrders();
        })();
    </script>
}
