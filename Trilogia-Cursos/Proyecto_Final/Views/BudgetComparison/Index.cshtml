@model Proyecto_Final.Models.Admin.BudgetComparisonDashboardViewModel
@{ ViewData["Title"] = "Presupuesto vs. real"; string Color(string s)=>s=="Excedido"?"danger":s=="Crítico"?"danger":s=="Advertencia"?"warning":"success"; }
<div class="container-fluid py-4 px-xl-5"><div class="d-flex flex-wrap justify-content-between align-items-center mb-3"><div><h2>Presupuesto vs. real</h2><p class="text-muted">Comparación autoritativa y proyección determinista (CU-223).</p></div><div><a asp-action="ExportCsv" asp-route-Year="@Model.Filter.Year" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-Month="@Model.Filter.Month" asp-route-CategoryId="@Model.Filter.CategoryId" asp-route-ExpenseStatus="@Model.Filter.ExpenseStatus" class="btn btn-outline-success">CSV</a> <a asp-action="Print" asp-route-Year="@Model.Filter.Year" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-Month="@Model.Filter.Month" asp-route-CategoryId="@Model.Filter.CategoryId" asp-route-ExpenseStatus="@Model.Filter.ExpenseStatus" class="btn btn-outline-secondary">Imprimir</a></div></div>
<div class="card mb-3"><div class="card-body"><form method="get" class="form-row"><div class="col-md-2"><input type="number" name="Year" value="@Model.Filter.Year" min="2000" max="2100" class="form-control"/></div><div class="col-md-3"><select name="DepartmentId" class="form-control"><option value="">Todos los departamentos</option>@foreach(var x in Model.Departments){<option value="@x.Id">@x.Name</option>}</select></div><div class="col-md-2"><select name="Month" class="form-control"><option value="">Año completo</option>@for(var i=1;i<=12;i++){<option value="@i">Mes @i</option>}</select></div><div class="col-md-2"><select name="CategoryId" class="form-control"><option value="">Todas las categorías</option>@foreach(var x in Model.Categories){<option value="@x.Id">@x.Name</option>}</select></div><div class="col-md-2"><select name="ExpenseStatus" class="form-control"><option value="">Todos los estados</option><option>Registrado</option><option>Aprobado</option><option>Pagado</option><option>Rechazado</option></select></div><div class="col-md-1"><button class="btn btn-dark btn-block" title="Actualizar"><i class="fa fa-sync"></i></button></div></form></div></div>
<div class="row mb-3"><div class="col-md-3"><div class="card p-3"><small>Presupuesto filtrado</small><strong class="h4">₡@Model.Summary.FilteredBudget.ToString("N2")</strong></div></div><div class="col-md-3"><div class="card p-3"><small>Real (aprobado + pagado)</small><strong class="h4">₡@Model.Summary.RealExpense.ToString("N2")</strong></div></div><div class="col-md-3"><div class="card p-3"><small>Disponible</small><strong class="h4 @(Model.Summary.Available<0?"text-danger":"text-success")">₡@Model.Summary.Available.ToString("N2")</strong></div></div><div class="col-md-3"><div class="card p-3"><small>Ejecución / proyección anual</small><strong class="h4 text-@Color(Model.Summary.Level)">@Model.Summary.ExecutionPercent.ToString("N1")% · ₡@Model.Summary.AnnualProjection.ToString("N2")</strong></div></div></div>
<div class="row mb-3"><div class="col-lg-6"><div class="card h-100"><div class="card-header">Por departamento</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Departamento</th><th>Presupuesto</th><th>Real</th><th>Ejecución</th></tr></thead><tbody>@foreach(var r in Model.ByDepartment){<tr><td>@r.Name</td><td>₡@r.Budget.ToString("N2")</td><td>₡@r.Real.ToString("N2")</td><td><span class="badge badge-@Color(r.Level)">@r.ExecutionPercent.ToString("N1")%</span></td></tr>}</tbody></table></div></div></div><div class="col-lg-6"><div class="card h-100"><div class="card-header">Por categoría</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Categoría</th><th>Presupuesto</th><th>Pendiente</th><th>Real</th></tr></thead><tbody>@foreach(var r in Model.ByCategory){<tr><td>@r.Name</td><td>₡@r.Budget.ToString("N2")</td><td>₡@r.Pending.ToString("N2")</td><td><span class="badge badge-@Color(r.Level)">₡@r.Real.ToString("N2")</span></td></tr>}</tbody></table></div></div></div></div>
<div class="card mb-3"><div class="card-header">Serie mensual (barra = real / presupuesto)</div><div class="card-body">@foreach(var m in Model.Monthly){var pct=m.Budget<=0?0:Math.Min(100,(int)(m.Real/m.Budget*100));<div class="d-flex align-items-center mb-2"><span style="width:55px">Mes @m.Month</span><div class="progress flex-grow-1 mr-2" style="height:18px"><div class="progress-bar @(m.Real>m.Budget?"bg-danger":"bg-primary")" style="width:@pct%"></div></div><small>₡@m.Real.ToString("N0") / ₡@m.Budget.ToString("N0")</small></div>}</div></div>
<div class="alert alert-info">Pendiente: ₡@Model.Summary.PendingExpense.ToString("N2") · Departamentos sin presupuesto: @Model.Summary.DepartmentsWithoutBudget · Categorías excedidas: @Model.Summary.OverBudgetCategories · Actualizado @Model.UpdatedUtc.ToString("dd/MM/yyyy HH:mm") UTC</div>
<div class="card"><div class="card-header">Detalle de gastos (drill-down)</div><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Fecha</th><th>Departamento / categoría</th><th>Documento</th><th>Estado</th><th>Total</th></tr></thead><tbody>@if(!Model.ExpenseDetail.Items.Any()){<tr><td colspan="5" class="text-center py-4">Sin gastos.</td></tr>}@foreach(var e in Model.ExpenseDetail.Items){<tr><td>@e.ExpenseDate.ToString("dd/MM/yyyy")</td><td>@e.DepartmentName<small class="d-block">@e.CategoryName</small></td><td><a asp-controller="Expenses" asp-action="Details" asp-route-id="@e.ExpenseId">@e.DocumentNumber</a></td><td>@e.Status</td><td>₡@e.Total.ToString("N2")</td></tr>}</tbody></table></div><div class="card-footer d-flex justify-content-between"><span>@Model.ExpenseDetail.Total gasto(s)</span><span>@if(Model.ExpenseDetail.Page>1){<a asp-route-Page="@(Model.ExpenseDetail.Page-1)" asp-route-Year="@Model.Filter.Year" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-Month="@Model.Filter.Month" asp-route-CategoryId="@Model.Filter.CategoryId" asp-route-ExpenseStatus="@Model.Filter.ExpenseStatus" class="btn btn-sm btn-outline-secondary">Anterior</a>} @if(Model.ExpenseDetail.Page<Model.ExpenseDetail.TotalPages){<a asp-route-Page="@(Model.ExpenseDetail.Page+1)" asp-route-Year="@Model.Filter.Year" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-Month="@Model.Filter.Month" asp-route-CategoryId="@Model.Filter.CategoryId" asp-route-ExpenseStatus="@Model.Filter.ExpenseStatus" class="btn btn-sm btn-outline-secondary">Siguiente</a>}</span></div></div></div>
