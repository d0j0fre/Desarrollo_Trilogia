@model Proyecto_Final.Models.Admin.BudgetComparisonDashboardViewModel
@{ Layout = null; }
<!doctype html><html lang="es"><head><meta charset="utf-8"/><title>Presupuesto vs. real @Model.Filter.Year</title><style>body{font-family:Arial;margin:32px;color:#222}table{border-collapse:collapse;width:100%;margin:18px 0}th,td{border:1px solid #aaa;padding:7px;text-align:left}.num{text-align:right}.muted{color:#666}@@media print{button{display:none}}</style></head><body><button onclick="window.print()">Imprimir</button><h1>Presupuesto vs. real · @Model.Filter.Year</h1><p class="muted">Generado @Model.UpdatedUtc.ToString("dd/MM/yyyy HH:mm") UTC</p><table><tr><th>Presupuesto</th><th>Real</th><th>Pendiente</th><th>Disponible</th><th>Ejecución</th><th>Proyección</th></tr><tr><td class="num">₡@Model.Summary.FilteredBudget.ToString("N2")</td><td class="num">₡@Model.Summary.RealExpense.ToString("N2")</td><td class="num">₡@Model.Summary.PendingExpense.ToString("N2")</td><td class="num">₡@Model.Summary.Available.ToString("N2")</td><td class="num">@Model.Summary.ExecutionPercent.ToString("N2")%</td><td class="num">₡@Model.Summary.AnnualProjection.ToString("N2")</td></tr></table><h2>Por departamento</h2><table><tr><th>Departamento</th><th>Presupuesto</th><th>Pendiente</th><th>Real</th><th>Disponible</th></tr>@foreach(var r in Model.ByDepartment){<tr><td>@r.Name</td><td class="num">₡@r.Budget.ToString("N2")</td><td class="num">₡@r.Pending.ToString("N2")</td><td class="num">₡@r.Real.ToString("N2")</td><td class="num">₡@r.Available.ToString("N2")</td></tr>}</table><h2>Detalle</h2><table><tr><th>Fecha</th><th>Departamento</th><th>Categoría</th><th>Documento</th><th>Estado</th><th>Total</th></tr>@foreach(var e in Model.ExpenseDetail.Items){<tr><td>@e.ExpenseDate.ToString("dd/MM/yyyy")</td><td>@e.DepartmentName</td><td>@e.CategoryName</td><td>@e.DocumentNumber</td><td>@e.Status</td><td class="num">₡@e.Total.ToString("N2")</td></tr>}</table></body></html>
