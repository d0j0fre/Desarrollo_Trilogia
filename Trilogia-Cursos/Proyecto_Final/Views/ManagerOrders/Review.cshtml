@model Proyecto_Final.Models.Admin.ManagerOrderReviewViewModel
@{
    ViewData["Title"] = $"Revisar pedido #{Model.Pedido.PedidoId}";
}

@section Styles {
    <style>
        .action-card {
            border-radius: 12px;
            padding: 24px;
        }
        .approve-card { border: 2px solid #198754; background: #f0fdf4; }
        .reject-card  { border: 2px solid #dc3545; background: #fff5f5; }
    </style>
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div>
                    <h2 class="mb-1">Revisar pedido #@Model.Pedido.PedidoId</h2>
                    <p class="mb-0">Aprueba o rechaza el pedido retenido. La decisión es definitiva.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary mt-3 mt-md-0">
                    <i class="fa fa-arrow-left mr-1"></i> Volver a retenidos
                </a>
            </div>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="row px-xl-5">
            <div class="col-12"><div class="alert alert-danger">@TempData["ErrorMessage"]</div></div>
        </div>
    }

    <div class="row px-xl-5">
        <div class="col-lg-7 mb-4">

            <div class="admin-card mb-4">
                <h5 class="mb-4">Información del pedido</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block text-muted small">Cliente</label>
                        <span>@Model.Pedido.Cliente</span>
                        <small class="d-block text-muted">@Model.Pedido.Correo</small>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block text-muted small">Fecha del pedido</label>
                        <span>@Model.Pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block text-muted small">Tipo de entrega</label>
                        <span>@(Model.Pedido.TipoEntrega ?? "—")</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block text-muted small">Estado</label>
                        <span class="admin-badge-soft warning">@Model.Pedido.Estado</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Pedido.DireccionEntrega))
                    {
                        <div class="col-12 mb-3">
                            <label class="font-weight-bold d-block text-muted small">Dirección de entrega</label>
                            <span>@Model.Pedido.DireccionEntrega</span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Pedido.Observaciones))
                    {
                        <div class="col-12 mb-3">
                            <label class="font-weight-bold d-block text-muted small">Observaciones</label>
                            <span>@Model.Pedido.Observaciones</span>
                        </div>
                    }
                </div>
            </div>

            <div class="admin-card">
                <h5 class="mb-3">Productos del pedido</h5>
                <div class="table-responsive">
                    <table class="table table-sm admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cant.</th>
                                <th class="text-right">Precio unit.</th>
                                <th class="text-right">Subtotal</th>
                                <th class="text-center">Stock actual</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Pedido.Detalles)
                            {
                                var stockOk = item.
                                StockActual >= item.Cantidad;
                                <tr class="@(stockOk ? "" : "table-danger")">
                                    <td>@item.Producto</td>
                                    <td class="text-center">@item.Cantidad</td>
                                    <td class="text-right">₡@item.PrecioUnitario.ToString("N2")</td>
                                    <td class="text-right">₡@item.Subtotal.ToString("N2")</td>
                                    <td class="text-center">
                                        <span class="badge @(stockOk ? "badge-success" : "badge-danger")">
                                            @item.StockActual
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-right font-weight-bold">Total del pedido:</td>
                                <td class="text-right font-weight-bold text-primary">
                                    ₡@Model.Pedido.Total.ToString("N2")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                @if (Model.Pedido.Detalles.Any(d => d.StockActual < d.Cantidad))
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="fa fa-exclamation-triangle mr-1"></i>
                        Uno o más productos no tienen stock suficiente. Si aprueba, el sistema re-validará el stock en tiempo real.
                    </div>
                }
            </div>

        </div>

        <div class="col-lg-5 mb-4">

            <div class="action-card approve-card mb-4">
                <h5 class="text-success mb-2"><i class="fa fa-check-circle mr-1"></i> Aprobar pedido</h5>
                <p class="text-muted small mb-3">
                    Al aprobar: el inventario se descuenta y la factura se genera automáticamente (CU-091).
                </p>
                <form asp-action="Approve" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="pedidoId" value="@Model.Pedido.PedidoId" />
                    <button type="submit" class="btn btn-success btn-block"
                            onclick="return confirm('¿Confirma la aprobación del pedido #@Model.Pedido.PedidoId? Se descontará el inventario y se generará la factura.')">
                        <i class="fa fa-check mr-1"></i> Aprobar y facturar
                    </button>
                </form>
            </div>

            <div class="action-card reject-card">
                <h5 class="text-danger mb-2"><i class="fa fa-times-circle mr-1"></i> Rechazar pedido</h5>
                <p class="text-muted small mb-3">
                    Al rechazar: el pedido se marca como rechazado y el vendedor verá el motivo en su panel.
                    No se afecta el inventario.
                </p>
                <form asp-action="Reject" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="RechazarForm.PedidoId" />

                    <div class="form-group">
                        <label asp-for="RechazarForm.MotivoRechazo" class="font-weight-bold small"></label>
                        <textarea asp-for="RechazarForm.MotivoRechazo"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Explique el motivo del rechazo (crédito insuficiente, producto no disponible, pedido duplicado...)"></textarea>
                        <span asp-validation-for="RechazarForm.MotivoRechazo" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-danger btn-block">
                        <i class="fa fa-times mr-1"></i> Rechazar pedido
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
