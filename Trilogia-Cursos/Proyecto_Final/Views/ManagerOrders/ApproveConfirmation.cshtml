@model Proyecto_Final.Models.Admin.ManagerApproveResultViewModel
@{
    ViewData["Title"] = "Pedido liberado";
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5 justify-content-center">
        <div class="col-lg-7">

            <div class="admin-card text-center py-5 mb-4" style="border-left: 5px solid #198754;">
                <div class="mb-3">
                    <i class="fa fa-check-circle text-success" style="font-size:64px;"></i>
                </div>
                <h2 class="mb-2">Pedido aprobado y facturado</h2>
                <p class="text-muted mb-0">
                    El pedido fue liberado, el inventario descontado y la factura generada automáticamente.
                </p>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3">
                    <div class="admin-card text-center py-4">
                        <div class="text-muted small mb-1">Número de pedido</div>
                        <div class="font-weight-bold" style="font-size:1.6rem;">#@Model.PedidoId</div>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="admin-card text-center py-4">
                        <div class="text-muted small mb-1">Estado</div>
                        <span class="admin-badge-soft success" style="font-size:1rem; padding:6px 18px;">
                            @Model.Estado
                        </span>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.NumeroFactura))
            {
                <div class="admin-card mb-4 text-center py-4">
                    <div class="text-muted small mb-2">Factura generada automáticamente (CU-091)</div>
                    <div class="font-weight-bold text-success" style="font-size:1.5rem;">
                        @Model.NumeroFactura
                    </div>
                </div>
            }

            <div class="d-flex flex-column flex-md-row justify-content-center" style="gap:12px;">
                <a asp-action="Index" class="btn btn-primary btn-lg">
                    <i class="fa fa-list mr-1"></i> Ver más retenidos
                </a>
                <a asp-controller="OrdersAdmin" asp-action="Detail" asp-route-id="@Model.PedidoId"
                   class="btn btn-outline-secondary btn-lg">
                    <i class="fa fa-eye mr-1"></i> Ver detalle del pedido
                </a>
            </div>

        </div>
    </div>
</div>
