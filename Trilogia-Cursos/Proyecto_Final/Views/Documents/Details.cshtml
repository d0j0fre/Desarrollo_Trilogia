@model Proyecto_Final.Models.Admin.DocumentDetailsViewModel
@{ ViewData["Title"] = Model.Document.Title; }
<div class="container py-4"><div class="d-flex justify-content-between align-items-center mb-3"><div><h2>@Model.Document.Title</h2><p class="text-muted">@Model.Document.TypeName · @(Model.Document.DepartmentName ?? "General")</p></div><div><a asp-action="Index" class="btn btn-outline-secondary">Volver</a> <a asp-action="Edit" asp-route-id="@Model.Document.DocumentId" class="btn btn-outline-primary">Editar</a></div></div>
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
<div class="row"><div class="col-lg-7"><div class="card mb-3"><div class="card-body"><dl class="row mb-0"><dt class="col-sm-4">Referencia</dt><dd class="col-sm-8">@(Model.Document.ReferenceNumber ?? "—")</dd><dt class="col-sm-4">Emisión</dt><dd class="col-sm-8">@(Model.Document.IssueDate?.ToString("dd/MM/yyyy") ?? "—")</dd><dt class="col-sm-4">Vencimiento</dt><dd class="col-sm-8">@(Model.Document.DoesNotExpire ? "No vence" : Model.Document.ExpirationDate?.ToString("dd/MM/yyyy")) (@Model.Document.ExpirationStatus)</dd><dt class="col-sm-4">Descripción</dt><dd class="col-sm-8">@(Model.Description ?? "—")</dd><dt class="col-sm-4">Archivo actual</dt><dd class="col-sm-8">@Model.OriginalName · @((Model.SizeBytes / 1024m).ToString("N1")) KB<br/><code>@Model.Sha256</code></dd></dl><a asp-action="Download" asp-route-id="@Model.Document.DocumentId" class="btn btn-primary mt-3"><i class="fa fa-download"></i> Descargar</a></div></div></div>
<div class="col-lg-5"><div class="card mb-3"><div class="card-header">Nueva versión</div><div class="card-body"><form asp-action="ReplaceFile" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Document.DocumentId" /><input type="file" name="file" accept=".pdf,.jpg,.jpeg,.png" class="form-control-file mb-3" required/><button class="btn btn-warning">Reemplazar archivo</button></form><hr/><form asp-action="SetActive" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Document.DocumentId"/><input type="hidden" name="active" value="@(!Model.Document.Active ? "true" : "false")"/><button class="btn btn-outline-danger">@(Model.Document.Active ? "Desactivar (borrado lógico)" : "Reactivar")</button></form></div></div></div></div>
<div class="card"><div class="card-header">Historial de versiones</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Versión</th><th>Archivo</th><th>Hash SHA-256</th><th>Creación UTC</th><th></th></tr></thead><tbody>@foreach(var version in Model.Versions){<tr><td>v@version.Version <span class="badge badge-light">@version.StorageStatus</span></td><td>@version.OriginalName</td><td><code>@version.Sha256</code></td><td>@version.CreatedUtc.ToString("dd/MM/yyyy HH:mm") · @version.CreatedByName</td><td><a asp-action="Download" asp-route-id="@Model.Document.DocumentId" asp-route-versionId="@version.VersionId" class="btn btn-sm btn-outline-primary">Descargar</a></td></tr>}</tbody></table></div></div></div>
