@model Proyecto_Final.Models.Admin.DocumentFormViewModel
@{ ViewData["Title"] = "Nuevo documento"; }
<div class="container py-4"><div class="d-flex justify-content-between align-items-center mb-3"><div><h2>Nuevo documento</h2><p class="text-muted mb-0">El archivo se validará y guardará fuera de wwwroot.</p></div><a asp-action="Index" class="btn btn-outline-secondary">Volver</a></div>
<div class="card shadow-sm"><div class="card-body"><form asp-action="Create" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()<partial name="_Form" model="Model" /><button class="btn btn-primary"><i class="fa fa-lock mr-1"></i>Guardar documento</button></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
