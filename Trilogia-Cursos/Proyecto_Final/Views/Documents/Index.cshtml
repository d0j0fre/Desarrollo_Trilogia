@model Proyecto_Final.Models.Admin.DocumentIndexViewModel
@{ ViewData["Title"] = "Documentos digitales"; string Badge(string s) => s == "Vencido" ? "danger" : s == "Por vencer" ? "warning" : "success"; }
<div class="container-fluid py-4 px-xl-5">
<div class="d-flex flex-wrap justify-content-between align-items-center mb-3"><div><h2>Documentos digitales</h2><p class="text-muted">Repositorio privado, versionado y trazable (CU-201).</p></div><div><a asp-action="Alerts" class="btn btn-outline-warning mr-2"><i class="fa fa-bell"></i> Alertas</a><a asp-action="Create" class="btn btn-primary"><i class="fa fa-plus"></i> Nuevo</a></div></div>
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
<div class="row mb-3"><div class="col-md-3"><div class="card p-3"><small>Vigentes</small><strong class="h4">@Model.CurrentCount</strong></div></div><div class="col-md-3"><div class="card p-3"><small>Por vencer</small><strong class="h4 text-warning">@Model.WarningCount</strong></div></div><div class="col-md-3"><div class="card p-3"><small>Vencidos</small><strong class="h4 text-danger">@Model.ExpiredCount</strong></div></div><div class="col-md-3"><div class="card p-3"><small>Sin vencimiento</small><strong class="h4">@Model.NoExpirationCount</strong></div></div></div>
<div class="card mb-3"><div class="card-body"><form method="get" class="form-row"><div class="col-md-3 mb-2"><input name="Search" value="@Model.Filter.Search" class="form-control" placeholder="Buscar título o referencia" /></div><div class="col-md-2 mb-2"><select name="TypeId" class="form-control"><option value="">Todos los tipos</option>@foreach(var x in Model.Types){<option value="@x.Id">@x.Name</option>}</select></div><div class="col-md-2 mb-2"><select name="DepartmentId" class="form-control"><option value="">Todos los departamentos</option>@foreach(var x in Model.Departments){<option value="@x.Id">@x.Name</option>}</select></div><div class="col-md-2 mb-2"><select name="Status" class="form-control"><option value="">Todos los estados</option><option>Vigente</option><option>Suspendido</option><option>Archivado</option></select></div><div class="col-md-2 mb-2"><select name="Expiration" class="form-control"><option value="">Todo vencimiento</option><option>Vigente</option><option>Por vencer</option><option>Vencido</option><option>No vence</option></select></div><div class="col-md-2 mb-2"><button class="btn btn-dark btn-block">Filtrar</button></div></form></div></div>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Documento</th><th>Tipo / departamento</th><th>Vencimiento</th><th>Versión</th><th>Estado</th><th></th></tr></thead><tbody>
@if (!Model.Documents.Items.Any()) { <tr><td colspan="6" class="text-center py-4 text-muted">No hay documentos para los filtros seleccionados.</td></tr> }
@foreach(var item in Model.Documents.Items){<tr><td><strong>@item.Title</strong><small class="d-block text-muted">@(item.ReferenceNumber ?? "Sin referencia")</small></td><td>@item.TypeName<small class="d-block text-muted">@(item.DepartmentName ?? "General")</small></td><td>@(item.DoesNotExpire ? "No vence" : item.ExpirationDate?.ToString("dd/MM/yyyy")) <span class="badge badge-@Badge(item.ExpirationStatus)">@item.ExpirationStatus</span></td><td>v@item.Version</td><td><span class="badge badge-@(item.Active ? "success" : "secondary")">@(item.Active ? item.Status : "Inactivo")</span></td><td><a asp-action="Details" asp-route-id="@item.DocumentId" class="btn btn-sm btn-outline-primary">Ver</a></td></tr>}
</tbody></table></div><div class="card-footer d-flex justify-content-between"><span>Página @Model.Documents.Page de @Model.Documents.TotalPages · @Model.Documents.Total resultado(s)</span><span>@if(Model.Documents.Page>1){<a asp-route-Page="@(Model.Documents.Page-1)" asp-route-Search="@Model.Filter.Search" asp-route-TypeId="@Model.Filter.TypeId" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-Status="@Model.Filter.Status" asp-route-Expiration="@Model.Filter.Expiration" class="btn btn-sm btn-outline-secondary">Anterior</a>} @if(Model.Documents.Page<Model.Documents.TotalPages){<a asp-route-Page="@(Model.Documents.Page+1)" asp-route-Search="@Model.Filter.Search" asp-route-TypeId="@Model.Filter.TypeId" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-Status="@Model.Filter.Status" asp-route-Expiration="@Model.Filter.Expiration" class="btn btn-sm btn-outline-secondary">Siguiente</a>}</span></div></div></div>
