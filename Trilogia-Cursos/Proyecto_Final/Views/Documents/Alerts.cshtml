@model Proyecto_Final.Models.Admin.DocumentAlertsIndexViewModel
@{ ViewData["Title"] = "Alertas documentales"; }
<div class="container-fluid py-4 px-xl-5"><div class="d-flex justify-content-between align-items-center mb-3"><div><h2>Alertas de vencimiento</h2><p class="text-muted">Fecha de negocio: Costa Rica. Generación idempotente (CU-202).</p></div><div><a asp-action="Index" class="btn btn-outline-secondary">Documentos</a> <form asp-action="GenerateAlerts" method="post" class="d-inline">@Html.AntiForgeryToken()<button class="btn btn-warning"><i class="fa fa-sync"></i> Generar ahora</button></form></div></div>
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
<div class="row mb-3"><div class="col-md-3"><div class="card p-3"><small>Activas</small><strong class="h3">@Model.ActiveCount</strong></div></div><div class="col-md-3"><div class="card p-3"><small>Vencidas</small><strong class="h3 text-danger">@Model.ExpiredCount</strong></div></div></div>
<div class="card mb-3"><div class="card-body"><form method="get" class="form-row"><div class="col-md-3"><select name="Status" class="form-control"><option value="">Todos los estados</option><option>Activa</option><option>Atendida</option></select></div><div class="col-md-3"><select name="DepartmentId" class="form-control"><option value="">Todos los departamentos</option>@foreach(var d in Model.Departments){<option value="@d.Id">@d.Name</option>}</select></div><div class="col-md-3"><input type="number" name="MaxDays" class="form-control" min="0" max="365" placeholder="Máximo de días"/></div><div class="col-md-2"><button class="btn btn-dark btn-block">Filtrar</button></div></form></div></div>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Documento</th><th>Responsable</th><th>Vence</th><th>Días</th><th>Estado</th><th></th></tr></thead><tbody>@if(!Model.Alerts.Items.Any()){<tr><td colspan="6" class="text-center py-4 text-muted">No hay alertas.</td></tr>}@foreach(var a in Model.Alerts.Items){<tr><td><a asp-action="Details" asp-route-id="@a.DocumentId">@a.DocumentTitle</a><small class="d-block text-muted">@a.TypeName · @(a.DepartmentName ?? "General")</small></td><td>@a.ResponsibleName</td><td>@a.ExpirationDate.ToString("dd/MM/yyyy")</td><td class="font-weight-bold @(a.DaysRemaining < 0 ? "text-danger" : "")">@a.DaysRemaining</td><td>@a.Status · @a.ExpirationStatus</td><td>@if(a.Status == "Activa"){<form asp-action="MarkAlertHandled" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@a.AlertId"/><button class="btn btn-sm btn-outline-success">Atendida</button></form>}</td></tr>}</tbody></table></div><div class="card-footer d-flex justify-content-between"><span>@Model.Alerts.Total alerta(s)</span><span>@if(Model.Alerts.Page>1){<a asp-route-Page="@(Model.Alerts.Page-1)" asp-route-Status="@Model.Filter.Status" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-MaxDays="@Model.Filter.MaxDays" class="btn btn-sm btn-outline-secondary">Anterior</a>} @if(Model.Alerts.Page<Model.Alerts.TotalPages){<a asp-route-Page="@(Model.Alerts.Page+1)" asp-route-Status="@Model.Filter.Status" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-MaxDays="@Model.Filter.MaxDays" class="btn btn-sm btn-outline-secondary">Siguiente</a>}</span></div></div></div>
