@model Proyecto_Final.Models.Admin.DocumentFormViewModel
@using Proyecto_Final.Models.Admin
@{
    var types = ViewBag.Types as IReadOnlyList<SelectOptionViewModel> ?? Array.Empty<SelectOptionViewModel>();
    var departments = ViewBag.Departments as IReadOnlyList<SelectOptionViewModel> ?? Array.Empty<SelectOptionViewModel>();
}
<input asp-for="DocumentId" type="hidden" />
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="form-row">
    <div class="form-group col-md-6"><label asp-for="TypeId">Tipo</label><select asp-for="TypeId" class="form-control"><option value="">Seleccione</option>@foreach (var item in types) { <option value="@item.Id">@item.Name</option> }</select><span asp-validation-for="TypeId" class="text-danger"></span></div>
    <div class="form-group col-md-6"><label asp-for="DepartmentId">Departamento responsable</label><select asp-for="DepartmentId" class="form-control"><option value="">General</option>@foreach (var item in departments) { <option value="@item.Id">@item.Name</option> }</select></div>
</div>
<div class="form-group"><label asp-for="Title">Título</label><input asp-for="Title" class="form-control" /><span asp-validation-for="Title" class="text-danger"></span></div>
<div class="form-group"><label asp-for="Description">Descripción</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
<div class="form-row">
    <div class="form-group col-md-4"><label asp-for="ReferenceNumber">Referencia</label><input asp-for="ReferenceNumber" class="form-control" /></div>
    <div class="form-group col-md-4"><label asp-for="IssueDate">Emisión</label><input asp-for="IssueDate" class="form-control" /></div>
    <div class="form-group col-md-4"><label asp-for="ExpirationDate">Vencimiento</label><input asp-for="ExpirationDate" class="form-control" /><span asp-validation-for="ExpirationDate" class="text-danger"></span></div>
</div>
<div class="form-row">
    <div class="form-group col-md-6"><div class="custom-control custom-checkbox mt-4"><input asp-for="DoesNotExpire" class="custom-control-input" /><label asp-for="DoesNotExpire" class="custom-control-label">No vence</label></div></div>
    <div class="form-group col-md-6"><label asp-for="Status">Estado</label><select asp-for="Status" class="form-control"><option>Vigente</option><option>Suspendido</option><option>Archivado</option></select></div>
</div>
@if (Model.DocumentId == 0)
{
    <div class="form-group"><label asp-for="File">Archivo privado (PDF, JPG o PNG; máx. 10 MB)</label><input asp-for="File" type="file" class="form-control-file" accept=".pdf,.jpg,.jpeg,.png" required /><span asp-validation-for="File" class="text-danger"></span></div>
}
