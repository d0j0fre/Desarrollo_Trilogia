@model Proyecto_Final.Models.Store.ClientPortalInvoiceViewModel
@{
    ViewData["Title"] = "Comprobante de pedido";
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
    <style>
        @@media print {
            .topbar,
            .modern-nav-shell,
            .navbar,
            .header-categories-button,
            .header-categories-panel,
            .user-panel,
            footer,
            .s3-footer,
            .back-to-top,
            .alert,
            .btn,
            .no-print {
                display: none !important;
            }

            @@page {
                margin: 12mm;
            }

            html,
            body {
                background: #fff !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            main,
            .container-fluid {
                margin: 0 !important;
                padding: 0 !important;
            }

            .admin-card,
            .admin-table-wrapper,
            .s4-client-invoice-document,
            .s4-client-invoice-card,
            .s4-client-invoice-products {
                box-shadow: none !important;
                border: 1px solid #ddd !important;
                break-inside: avoid;
                page-break-inside: avoid;
            }

            .s4-client-invoice-page,
            .s4-client-invoice-document {
                background: #fff !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            .s4-client-invoice-header,
            .s4-client-invoice-grid,
            .s4-client-invoice-meta {
                display: block !important;
            }

            .s4-client-invoice-brand,
            .s4-client-invoice-meta,
            .s4-client-invoice-card,
            .s4-client-invoice-totals,
            .s4-client-invoice-products {
                margin-bottom: 12px !important;
            }

            .s4-client-invoice-table {
                width: 100% !important;
            }

            .row,
            [class*="col-"] {
                display: block !important;
                max-width: 100% !important;
                width: 100% !important;
                flex: none !important;
            }

            a[href]::after {
                content: "";
            }

            tr {
                break-inside: avoid;
                page-break-inside: avoid;
            }
        }
    </style>
}

<div class="s4-client-invoice-page">
    <div class="container">
        <div class="s4-client-invoice-toolbar no-print">
            <div>
                <span>Portal del cliente</span>
                <h1>Comprobante de pedido</h1>
                <p>Consulta e imprime el comprobante generado por el sistema.</p>
            </div>

            <div class="s4-client-invoice-actions no-print">
                <a asp-controller="ClientPortal" asp-action="Detail" asp-route-id="@Model.PedidoId" class="s4-client-invoice-secondary">
                    Volver al detalle
                </a>
                <a asp-controller="ClientPortal" asp-action="Index" class="s4-client-invoice-secondary">
                    Mis pedidos
                </a>
                <button type="button" class="s4-client-invoice-primary" onclick="window.print();">
                    Imprimir
                </button>
            </div>
        </div>

        <section class="s4-client-invoice-document">
            <div class="s4-client-invoice-header">
                <div class="s4-client-invoice-brand">
                    <div class="s4-client-invoice-brand-heading">
                        <img src="~/brand/logo-icon.png"
                             asp-append-version="true"
                             class="s4-client-invoice-logo"
                             alt="Supermercado Mayoreo" />
                        <div>
                            <span>Supermercado Mayoreo</span>
                            <small>Licorera - Distribuidora</small>
                        </div>
                    </div>
                    <h2>Comprobante del sistema</h2>
                    <p>Pedido #@Model.PedidoId</p>
                </div>

                <div class="s4-client-invoice-meta">
                    <div>
                        <span>Numero de comprobante</span>
                        <strong>@Model.NumeroFactura</strong>
                    </div>
                    <div>
                        <span>Fecha</span>
                        <strong>@Model.FechaFactura.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                    <div>
                        <span>Pedido asociado</span>
                        <strong>#@Model.PedidoId</strong>
                    </div>
                </div>
            </div>

            <div class="s4-client-invoice-grid">
                <div class="s4-client-invoice-card">
                    <div class="s4-client-invoice-card-title">
                        <span>Cliente</span>
                        @{
                            var claseEstado = Model.Estado == "Generada" ? "success" : "dark";
                        }
                        <span class="s4-client-invoice-status @claseEstado">@Model.Estado</span>
                    </div>

                    <dl class="s4-client-invoice-facts">
                        <div>
                            <dt>Cliente</dt>
                            <dd>@Model.Cliente</dd>
                        </div>
                        <div>
                            <dt>Correo</dt>
                            <dd>@Model.Correo</dd>
                        </div>
                    </dl>

                    <p class="s4-client-invoice-disclaimer">
                        Este documento es un comprobante visible desde el portal del cliente. No sustituye una factura electronica oficial.
                    </p>
                </div>

                <aside class="s4-client-invoice-totals">
                    <h3>Totales</h3>

                    <div>
                        <span>Subtotal</span>
                        <strong>&#8353;@Model.Subtotal.ToString("N2")</strong>
                    </div>

                    <div>
                        <span>Impuesto</span>
                        <strong>&#8353;@Model.Impuesto.ToString("N2")</strong>
                    </div>

                    <div class="s4-client-invoice-total-row">
                        <span>Total</span>
                        <strong>&#8353;@Model.Total.ToString("N2")</strong>
                    </div>
                </aside>
            </div>

            <div class="s4-client-invoice-products">
                <div class="s4-client-invoice-products-head">
                    <span>Detalle</span>
                    <h3>Productos facturados</h3>
                </div>

                <div class="s4-client-invoice-table-wrap">
                    <table class="s4-client-invoice-table">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Cantidad</th>
                                <th>Precio unitario</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Lineas.Any())
                            {
                                <tr>
                                    <td colspan="4" class="s4-client-invoice-empty">No hay productos registrados para este comprobante.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model.Lineas)
                                {
                                    <tr>
                                        <td><strong>@item.Producto</strong></td>
                                        <td>@item.Cantidad</td>
                                        <td>&#8353;@item.PrecioUnitario.ToString("N2")</td>
                                        <td>&#8353;@item.Subtotal.ToString("N2")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-right">Subtotal</th>
                                <th>&#8353;@Model.Subtotal.ToString("N2")</th>
                            </tr>
                            <tr>
                                <th colspan="3" class="text-right">Impuesto</th>
                                <th>&#8353;@Model.Impuesto.ToString("N2")</th>
                            </tr>
                            <tr>
                                <th colspan="3" class="text-right">Total</th>
                                <th>&#8353;@Model.Total.ToString("N2")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </section>
    </div>
</div>
