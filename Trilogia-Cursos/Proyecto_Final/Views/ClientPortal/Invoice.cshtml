@model Proyecto_Final.Models.Store.ClientPortalInvoiceViewModel
@{
    ViewData["Title"] = "Comprobante de pedido";
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
    <style>
        @@media print {
            .topbar,
            .modern-nav-shell,
            .navbar,
            .header-categories-button,
            .header-categories-panel,
            .user-panel,
            footer,
            .s3-footer,
            .back-to-top,
            .alert,
            .btn,
            .no-print {
                display: none !important;
            }

            @@page {
                margin: 12mm;
            }

            html,
            body {
                background: #fff !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            main,
            .container-fluid {
                margin: 0 !important;
                padding: 0 !important;
            }

            .admin-card,
            .admin-table-wrapper {
                box-shadow: none !important;
                border: 1px solid #ddd !important;
                break-inside: avoid;
                page-break-inside: avoid;
            }

            .row,
            [class*="col-"] {
                display: block !important;
                max-width: 100% !important;
                width: 100% !important;
                flex: none !important;
            }

            a[href]::after {
                content: "";
            }

            tr {
                break-inside: avoid;
                page-break-inside: avoid;
            }
        }
    </style>
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5 no-print">
        <div class="col-12">
            <div class="admin-page-header d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="mb-2">Comprobante de pedido</h2>
                    <p>Consulta e imprime el comprobante generado por el sistema.</p>
                </div>
                <div class="d-flex flex-wrap">
                    <a asp-controller="ClientPortal" asp-action="Detail" asp-route-id="@Model.PedidoId" class="btn btn-outline-light mr-2 mb-2">
                        Volver al detalle
                    </a>
                    <a asp-controller="ClientPortal" asp-action="Index" class="btn btn-outline-light mr-2 mb-2">
                        Mis pedidos
                    </a>
                    <button type="button" class="btn btn-light mb-2" onclick="window.print();">
                        Imprimir
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-3">
        <div class="col-lg-8 pb-3">
            <div class="admin-card h-100">
                <h4 class="mb-1">Licorera La Bodega</h4>
                <p class="text-muted mb-4">Comprobante del sistema para el pedido #@Model.PedidoId</p>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block">Numero de comprobante</label>
                        <span>@Model.NumeroFactura</span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block">Estado</label>
                        @{
                            var claseEstado = Model.Estado == "Generada" ? "success" : "dark";
                        }
                        <span class="admin-badge-soft @claseEstado">@Model.Estado</span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block">Fecha</label>
                        <span>@Model.FechaFactura.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block">Pedido asociado</label>
                        <span>#@Model.PedidoId</span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block">Cliente</label>
                        <span>@Model.Cliente</span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold d-block">Correo</label>
                        <span>@Model.Correo</span>
                    </div>
                </div>

                <p class="text-muted mb-0">
                    Este documento es un comprobante visible desde el portal del cliente. No sustituye una factura electronica oficial.
                </p>
            </div>
        </div>

        <div class="col-lg-4 pb-3">
            <div class="admin-card h-100">
                <h5 class="mb-4">Totales</h5>

                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal</span>
                    <strong>&#8353;@Model.Subtotal.ToString("N2")</strong>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span>Impuesto</span>
                    <strong>&#8353;@Model.Impuesto.ToString("N2")</strong>
                </div>

                <hr />

                <div class="d-flex justify-content-between mb-0">
                    <span class="font-weight-bold">Total</span>
                    <strong>&#8353;@Model.Total.ToString("N2")</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="p-4 border-bottom">
                    <h5 class="mb-0">Productos facturados</h5>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Producto</th>
                                <th>Cantidad</th>
                                <th>Precio unitario</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Lineas.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">No hay productos registrados para este comprobante.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model.Lineas)
                                {
                                    <tr>
                                        <td class="font-weight-bold">@item.Producto</td>
                                        <td>@item.Cantidad</td>
                                        <td>&#8353;@item.PrecioUnitario.ToString("N2")</td>
                                        <td>&#8353;@item.Subtotal.ToString("N2")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-right">Subtotal</th>
                                <th>&#8353;@Model.Subtotal.ToString("N2")</th>
                            </tr>
                            <tr>
                                <th colspan="3" class="text-right">Impuesto</th>
                                <th>&#8353;@Model.Impuesto.ToString("N2")</th>
                            </tr>
                            <tr>
                                <th colspan="3" class="text-right">Total</th>
                                <th>&#8353;@Model.Total.ToString("N2")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
