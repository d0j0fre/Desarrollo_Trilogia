@model Proyecto_Final.Models.Store.ClientPortalIndexViewModel
@{
    ViewData["Title"] = "Mis pedidos";
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header">
                <h2 class="mb-2">Mis pedidos</h2>
                <p>Consulta tu informacion de cliente, credito disponible e historial de compras.</p>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-3">
        <div class="col-lg-4 pb-3">
            <div class="admin-card h-100">
                <h5 class="mb-3">Informacion del cliente</h5>
                <p class="mb-2"><strong>Nombre:</strong> @Model.Cliente.NombreCompleto</p>
                <p class="mb-2"><strong>Correo:</strong> @Model.Cliente.Correo</p>
                <p class="mb-2"><strong>Telefono:</strong> @(string.IsNullOrWhiteSpace(Model.Cliente.Telefono) ? "Sin telefono" : Model.Cliente.Telefono)</p>
                <p class="mb-2"><strong>Direccion:</strong> @(string.IsNullOrWhiteSpace(Model.Cliente.Direccion) ? "Sin direccion" : Model.Cliente.Direccion)</p>
                <p class="mb-0"><strong>Cliente desde:</strong> @Model.Cliente.FechaRegistro.ToString("dd/MM/yyyy")</p>
            </div>
        </div>

        <div class="col-lg-4 pb-3">
            <div class="admin-card h-100 text-center">
                <h5 class="mb-3">Historial</h5>
                <h3 class="mb-1">@Model.Cliente.TotalPedidos</h3>
                <p class="text-muted mb-3">Pedido(s)</p>
                <h4 class="mb-1">&#8353;@Model.Cliente.TotalComprado.ToString("N2")</h4>
                <p class="text-muted mb-3">Total comprado</p>
                <p class="mb-0"><strong>Ultimo pedido:</strong> @(Model.Cliente.UltimoPedido.HasValue ? Model.Cliente.UltimoPedido.Value.ToString("dd/MM/yyyy") : "Sin pedidos")</p>
            </div>
        </div>

        <div class="col-lg-4 pb-3">
            <div class="admin-card h-100 text-center">
                <h5 class="mb-3">Credito</h5>
                @if (Model.Credito == null)
                {
                    <p class="text-muted mb-0">No hay credito asignado actualmente.</p>
                }
                else
                {
                    <h3 class="@(Model.Credito.CreditoDisponible < 0 ? "text-danger" : "text-success") mb-1">&#8353;@Model.Credito.CreditoDisponible.ToString("N2")</h3>
                    <p class="text-muted mb-2">Credito disponible</p>
                    <p class="mb-1"><strong>Limite:</strong> &#8353;@Model.Credito.LimiteCredito.ToString("N2")</p>
                    <p class="mb-2"><strong>Deuda:</strong> &#8353;@Model.Credito.DeudaActual.ToString("N2")</p>

                    @if (Model.Credito.CreditoBloqueado)
                    {
                        <span class="badge badge-danger">Bloqueado</span>
                    }
                    else if (Model.Credito.CreditoActivo)
                    {
                        <span class="badge badge-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">Inactivo</span>
                    }
                }
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Historial de pedidos</h5>
                    <span class="badge badge-light">@Model.Pedidos.Count registro(s)</span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th># Pedido</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                                <th>Entrega</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Pedidos.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No hay pedidos registrados.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var pedido in Model.Pedidos)
                                {
                                    var claseEstado = pedido.Estado == "Pendiente" ? "warning" : pedido.Estado == "Entregado" ? "success" : pedido.Estado == "Cancelado" ? "danger" : "dark";
                                    <tr>
                                        <td class="font-weight-bold">#@pedido.PedidoId</td>
                                        <td>@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><span class="admin-badge-soft @claseEstado">@pedido.Estado</span></td>
                                        <td>@(string.IsNullOrWhiteSpace(pedido.TipoEntrega) ? "No indicado" : pedido.TipoEntrega)</td>
                                        <td>&#8353;@pedido.Total.ToString("N2")</td>
                                        <td class="text-right">
                                            <a asp-controller="ClientPortal" asp-action="Detail" asp-route-id="@pedido.PedidoId" class="btn btn-sm btn-outline-primary">
                                                Ver detalle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
