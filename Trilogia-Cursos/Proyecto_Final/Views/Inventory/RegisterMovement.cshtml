@model Proyecto_Final.Models.Admin.InventoryMovementFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Registrar movimiento";
    var productos = ViewBag.Productos as List<SelectListItem> ?? new List<SelectListItem>();
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header">
                <h2 class="mb-2">Registrar movimiento</h2>
                <p>Ingresa una entrada, salida o ajuste para actualizar correctamente el inventario.</p>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-lg-8">
            <div class="admin-card">
                <form asp-controller="Inventory" asp-action="RegisterMovement" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"
                         style="display:@(ViewContext.ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-row">
                        <div class="form-group col-md-12">
                            <label asp-for="ProductoId" class="font-weight-bold"></label>
                            <select asp-for="ProductoId" asp-items="productos" class="form-control">
                                <option value="">Seleccione un producto</option>
                            </select>
                            <span asp-validation-for="ProductoId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="TipoMovimiento" class="font-weight-bold"></label>
                            <select asp-for="TipoMovimiento" class="form-control">
                                <option value="Entrada">Entrada</option>
                                <option value="Salida">Salida</option>
                                <option value="Ajuste">Ajuste</option>
                            </select>
                            <span asp-validation-for="TipoMovimiento" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-6">
                            <label asp-for="Cantidad" class="font-weight-bold"></label>
                            <input asp-for="Cantidad" class="form-control" placeholder="Cantidad" />
                            <span asp-validation-for="Cantidad" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Motivo" class="font-weight-bold"></label>
                        <textarea asp-for="Motivo" class="form-control" rows="4" placeholder="Motivo del movimiento"></textarea>
                        <span asp-validation-for="Motivo" class="text-danger"></span>
                    </div>

                    <div class="d-flex flex-wrap mt-3">
                        <button type="submit" class="btn btn-primary mr-2 mb-2">
                            <i class="fa fa-save mr-2"></i>Guardar movimiento
                        </button>

                        <a asp-controller="Inventory" asp-action="Movements" class="btn btn-outline-secondary mb-2">
                            <i class="fa fa-arrow-left mr-2"></i>Volver a movimientos
                        </a>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="admin-card">
                <h5 class="mb-3">Guía rápida</h5>
                <ul class="contact-list">
                    <li><strong>Entrada:</strong> aumenta el stock actual.</li>
                    <li><strong>Salida:</strong> disminuye el stock actual.</li>
                    <li><strong>Ajuste:</strong> establece un valor directo de stock.</li>
                    <li>Agrega un motivo claro para dejar trazabilidad del cambio.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}