@model Proyecto_Final.Models.Admin.InventoryMovementFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Registrar movimiento";
    var productos = ViewBag.Productos as List<SelectListItem> ?? new List<SelectListItem>();
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page inventory-admin-page">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header">
                <h2 class="mb-2">Registrar movimiento</h2>
                <p>Ingresa una entrada, salida o ajuste para actualizar correctamente el inventario.</p>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-lg-8">
            <div class="admin-card">

                <form asp-controller="Inventory"
                      asp-action="RegisterMovement"
                      method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger mb-3"></div>

                    <div class="form-row">
                        <div class="form-group col-md-12">
                            <label asp-for="ProductoId" class="font-weight-bold"></label>

                            <select asp-for="ProductoId"
                                    asp-items="productos"
                                    class="form-control">

                                <option value="">Seleccione un producto</option>
                            </select>

                            <span asp-validation-for="ProductoId"
                                  class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">

                        <div class="form-group col-md-6">
                            <label asp-for="TipoMovimiento"
                                   class="font-weight-bold"></label>

                            <select asp-for="TipoMovimiento"
                                    id="tipoMovimiento"
                                    class="form-control">

                                <option value="Entrada">Entrada</option>
                                <option value="Salida">Salida</option>
                                <option value="Ajuste">Ajuste</option>
                            </select>

                            <span asp-validation-for="TipoMovimiento"
                                  class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-6">
                            <label asp-for="Cantidad"
                                   class="font-weight-bold"></label>

                            <input asp-for="Cantidad"
                                   class="form-control"
                                   placeholder="Cantidad" />

                            <span asp-validation-for="Cantidad"
                                  class="text-danger"></span>
                        </div>

                    </div>

                    <div id="datosGasto" class="border rounded p-3 mb-3">

                        <h5 class="mb-3">Información de la compra</h5>

                        <div class="form-group form-check">
                            <input asp-for="GeneraGasto"
                                   id="generaGasto"
                                   class="form-check-input" />

                            <label asp-for="GeneraGasto"
                                   class="form-check-label font-weight-bold">
                                Esta entrada representa una compra
                            </label>
                        </div>

                        <div id="camposGasto">

                            <div class="form-row">

                                <div class="form-group col-md-6">
                                    <label asp-for="CostoUnitario"
                                           class="font-weight-bold"></label>

                                    <input asp-for="CostoUnitario"
                                           type="number"
                                           min="0"
                                           step="0.01"
                                           class="form-control"
                                           placeholder="Costo por unidad" />

                                    <span asp-validation-for="CostoUnitario"
                                          class="text-danger"></span>
                                </div>

                                <div class="form-group col-md-6">
                                    <label asp-for="CategoriaGasto"
                                           class="font-weight-bold"></label>

                                    <select asp-for="CategoriaGasto"
                                            class="form-control">

                                        <option value="">Seleccione una categoría</option>
                                        <option value="Compra de inventario">
                                            Compra de inventario
                                        </option>
                                        <option value="Transporte">
                                            Transporte
                                        </option>
                                        <option value="Otro">
                                            Otro
                                        </option>
                                    </select>

                                    <span asp-validation-for="CategoriaGasto"
                                          class="text-danger"></span>
                                </div>

                            </div>

                            <div class="alert alert-info mb-0">
                                El gasto se calculará multiplicando la cantidad por el costo unitario.
                            </div>

                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Motivo"
                               class="font-weight-bold"></label>

                        <textarea asp-for="Motivo"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Motivo del movimiento"></textarea>

                        <span asp-validation-for="Motivo"
                              class="text-danger"></span>
                    </div>

                    <div class="d-flex flex-wrap mt-3">

                        <button type="submit"
                                class="btn btn-primary mr-2 mb-2">

                            <i class="fa fa-save mr-2"></i>
                            Guardar movimiento
                        </button>

                        <a asp-controller="Inventory"
                           asp-action="Movements"
                           class="btn btn-outline-secondary mb-2">

                            <i class="fa fa-arrow-left mr-2"></i>
                            Volver a movimientos
                        </a>

                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="admin-card">
                <h5 class="mb-3">Guía rápida</h5>

                <ul class="contact-list">
                    <li><strong>Entrada:</strong> aumenta el stock actual.</li>
                    <li><strong>Salida:</strong> disminuye el stock actual.</li>
                    <li><strong>Ajuste:</strong> establece un valor directo de stock.</li>
                    <li>
                        Marca “representa una compra” únicamente cuando exista una salida real de dinero.
                    </li>
                    <li>
                        Agrega un motivo claro para dejar trazabilidad del cambio.
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const tipoMovimiento = document.getElementById("tipoMovimiento");
            const datosGasto = document.getElementById("datosGasto");
            const generaGasto = document.getElementById("generaGasto");
            const camposGasto = document.getElementById("camposGasto");

            function actualizarFormulario() {
                const esEntrada = tipoMovimiento.value === "Entrada";

                datosGasto.style.display = esEntrada ? "block" : "none";

                camposGasto.style.display =
                    esEntrada && generaGasto.checked
                        ? "block"
                        : "none";
            }

            tipoMovimiento.addEventListener("change", actualizarFormulario);
            generaGasto.addEventListener("change", actualizarFormulario);

            actualizarFormulario();
        });
    </script>
}