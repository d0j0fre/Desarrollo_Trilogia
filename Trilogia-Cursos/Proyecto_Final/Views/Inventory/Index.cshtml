@model IEnumerable<Proyecto_Final.Models.Admin.ProductAdminViewModel>
@{
    ViewData["Title"] = "Inventario";
    var filtro = ViewBag.Filtro as string;
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
    <link href="~/css/ui-modern-2027.css" rel="stylesheet" />
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">Inventario</h2>
                    <p class="text-muted mb-0">Gestión de productos del catálogo.</p>
                </div>
                <a asp-controller="Inventory" asp-action="Create" class="btn btn-primary btn-modern-primary">
                    <i class="fa fa-plus mr-1"></i>Nuevo producto
                </a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 mb-3">
        <div class="col-12">
            <form asp-controller="Inventory" asp-action="Index" method="get" class="admin-filter-grid">
                <input type="text" name="filtro" value="@filtro"
                       class="form-control" placeholder="Buscar por nombre o categoría..." />
                <button type="submit" class="btn btn-dark"><i class="fa fa-search mr-1"></i>Buscar</button>
                @if (!string.IsNullOrWhiteSpace(filtro))
                {
                    <a asp-controller="Inventory" asp-action="Index" class="btn btn-outline-secondary"><i class="fa fa-times mr-1"></i>Limpiar</a>
                }
            </form>
        </div>
    </div>

    @{
        var productosConAlerta = Model.Where(p =>
            p.EstadoStock == "Agotado" ||
            p.EstadoStock == "Bajo" ||
            p.EstadoStock == "Stock bajo" ||
            p.Stock <= p.StockMinimo).ToList();
    }

    @if (productosConAlerta.Any())
    {
        <div class="row px-xl-5 mb-3">
            <div class="col-12">
                <div class="alert alert-warning d-flex align-items-start" role="alert">
                    <span style="font-size:1.4rem; margin-right:10px;">⚠️</span>
                    <div>
                        <strong>Alerta de inventario:</strong>
                        hay @productosConAlerta.Count producto(s) con stock bajo o agotado:
                        <ul class="mb-0 mt-1">
                            @foreach (var p in productosConAlerta)
                            {
                                <li>
                                    <strong>@p.Nombre</strong> —
                                    @(p.Stock <= 0
                                        ? "sin stock disponible"
                                        : $"stock actual {p.Stock}, mínimo configurado {p.StockMinimo}")
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>ID</th>
                                <th>Imagen</th>
                                <th>Nombre</th>
                                <th>Categoría</th>
                                <th>Destacado</th>
                                <th>Precio</th>
                                <th>Stock</th>
                                <th>Mínimo</th>
                                <th>Estado</th>
                                <th style="min-width:180px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="10" class="text-center text-muted py-4">
                                        @if (!string.IsNullOrWhiteSpace(filtro))
                                        {
                                            <span>No se encontraron productos para "<strong>@filtro</strong>".</span>
                                        }
                                        else
                                        {
                                            <span>No hay productos registrados aún.</span>
                                        }
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    var imagen = string.IsNullOrWhiteSpace(item.ImagenUrl)
                                        ? Url.Content("~/img/whisky-premium.webp")
                                        : Url.Content(item.ImagenUrl);

                                    var stockClass = item.Stock <= 0 ? "danger"
                                        : item.Stock <= item.StockMinimo ? "warning"
                                        : "success";

                                    var estadoStock = item.Stock <= 0 ? "Agotado"
                                        : item.Stock <= item.StockMinimo ? "Stock bajo"
                                        : "Disponible";

                                    <tr>
                                        <td>@item.ProductoId</td>
                                        <td>
                                            <img src="@imagen" class="table-product-thumb" />
                                        </td>
                                        <td class="font-weight-bold">@item.Nombre</td>
                                        <td>@item.Categoria</td>
                                        <td>
                                            <form asp-controller="Inventory" asp-action="ToggleFeatured" method="post" class="mb-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productoId" value="@item.ProductoId" />
                                                <input type="hidden" name="filtro" value="@filtro" />
                                                <button type="submit" class="btn btn-sm @(item.EsDestacado ? "btn-success" : "btn-outline-secondary")">
                                                    @(item.EsDestacado ? "Sí" : "No")
                                                </button>
                                            </form>
                                        </td>
                                        <td>₡@item.Precio.ToString("N2")</td>
                                        <td>
                                            <span class="badge badge-@stockClass">@item.Stock</span>
                                            <div class="small text-muted">@estadoStock</div>
                                        </td>
                                        <td>@item.StockMinimo</td>
                                        <td>
                                            @if (item.Activo)
                                            {
                                                <span class="badge badge-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">Inactivo</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="admin-actions admin-actions--products">
                                                <a asp-controller="Inventory" asp-action="Edit"
                                                   asp-route-id="@item.ProductoId" class="btn btn-sm btn-primary"><i class="fa fa-edit mr-1"></i>Editar</a>

                                                <form asp-controller="Inventory" asp-action="ToggleStatus" method="post" class="mb-0"
                                                      data-s3-confirm="@(item.Activo ? "¿Inactivar este producto? Ya no se mostrará en el catálogo." : "¿Reactivar este producto? Volverá a mostrarse en el catálogo.")"
                                                      data-s3-confirm-title="Confirmar cambio de producto"
                                                      data-s3-confirm-type="warning"
                                                      data-s3-confirm-ok="Sí, continuar"
                                                      data-s3-confirm-cancel="Cancelar">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="productoId" value="@item.ProductoId" />
                                                    <input type="hidden" name="filtro" value="@filtro" />
                                                    <button type="submit" class="btn btn-sm @(item.Activo ? "btn-warning" : "btn-success")">
                                                        <i class="fa @(item.Activo ? "fa-eye-slash" : "fa-eye") mr-1"></i>@(item.Activo ? "Inactivar" : "Reactivar")
                                                    </button>
                                                </form>

                                                <form asp-controller="Inventory" asp-action="DeletePermanent" method="post" class="mb-0"
                                                      data-s3-confirm="¿Eliminar definitivamente este producto? Solo se podrá eliminar si no tiene pedidos, facturas ni movimientos de inventario asociados."
                                                      data-s3-confirm-title="Confirmar eliminación definitiva"
                                                      data-s3-confirm-type="danger"
                                                      data-s3-confirm-ok="Eliminar"
                                                      data-s3-confirm-cancel="Cancelar">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="productoId" value="@item.ProductoId" />
                                                    <input type="hidden" name="filtro" value="@filtro" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa fa-trash mr-1"></i>Eliminar</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
