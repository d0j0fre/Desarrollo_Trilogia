@model IEnumerable<Proyecto_Final.Models.Admin.InventoryMovementViewModel>
@{
    ViewData["Title"] = "Movimientos de inventario";
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page inventory-admin-page">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header">
                <h2 class="mb-2">Movimientos de inventario</h2>
                <p>Consulta entradas, salidas y ajustes realizados sobre el stock de productos.</p>
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-filter-bar d-flex justify-content-between align-items-center flex-wrap">
                <div class="mb-2 mb-md-0">
                    <h5 class="mb-1">Historial de movimientos</h5>
                    <span class="text-muted">Total registros: @(Model?.Count() ?? 0)</span>
                </div>

                <div>
                    <a asp-controller="Inventory" asp-action="RegisterMovement" class="btn btn-dark">
                        <i class="fa fa-plus mr-2"></i>Registrar movimiento
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>ID</th>
                                <th>Producto</th>
                                <th>Tipo</th>
                                <th>Cantidad</th>
                                <th>Stock anterior</th>
                                <th>Stock nuevo</th>
                                <th>Motivo</th>
                                <th>Usuario</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        No hay movimientos registrados.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    var claseTipo = item.TipoMovimiento.Contains("Entrada", StringComparison.OrdinalIgnoreCase)
                                    ? "success"
                                    : item.TipoMovimiento.Contains("Salida", StringComparison.OrdinalIgnoreCase)
                                    ? "danger"
                                    : "warning";

                                    <tr>
                                        <td>@item.MovimientoId</td>
                                        <td class="font-weight-bold">@item.Producto</td>
                                        <td>
                                            <span class="admin-badge-soft @claseTipo">@item.TipoMovimiento</span>
                                        </td>
                                        <td>@item.Cantidad</td>
                                        <td>@item.StockAnterior</td>
                                        <td>@item.StockNuevo</td>
                                        <td>
                                            @(string.IsNullOrWhiteSpace(item.Motivo)
                                                                                ? "Sin detalle"
                                                                                : item.Motivo)
                                </td>
                                <td>@item.Usuario</td>
                                <td>@item.FechaMovimiento.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                                                        }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
