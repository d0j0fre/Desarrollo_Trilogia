@model Proyecto_Final.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Restablecer contraseña";
}

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-light mb-30">
                <a class="breadcrumb-item text-primary" asp-controller="Home" asp-action="Index">Inicio</a>
                <a class="breadcrumb-item text-primary" asp-controller="Account" asp-action="Login">Iniciar Sesión</a>
                <span class="breadcrumb-item active text-body">Restablecer contraseña</span>
            </nav>
        </div>
    </div>
</div>

<div class="container-fluid">
    <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4">
        <span class="text-secondary pr-3">Restablecer contraseña</span>
    </h2>

    <div class="row px-xl-5">
        <div class="col-lg-6 offset-lg-3 mb-5">
            <div class="contact-form bg-light p-30">
                <h4 class="text-secondary mb-4 text-center">Elegí tu nueva contraseña</h4>

                <form asp-controller="Account" asp-action="ResetPassword" method="post" novalidate="novalidate">
                    <input asp-for="Token" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="control-group mb-3">
                        <label asp-for="Password" class="text-body"></label>
                        <input asp-for="Password" class="form-control" placeholder="Nueva contraseña" />
                        <span asp-validation-for="Password" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-4">
                        <label asp-for="ConfirmPassword" class="text-body"></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirmá la contraseña" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger help-block"></span>
                    </div>

                    <div class="text-center">
                        <button class="btn btn-primary btn-block px-4 py-2" type="submit">CAMBIAR CONTRASEÑA</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
