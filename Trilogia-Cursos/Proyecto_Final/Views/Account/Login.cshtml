@model Proyecto_Final.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesion";
}

<div class="s4-auth-page">
    <div class="container">
        <nav class="s4-auth-breadcrumb">
            <a asp-controller="Home" asp-action="Index">Inicio</a>
            <span>Iniciar Sesion</span>
        </nav>

        <div class="s4-auth-shell">
            <aside class="s4-auth-hero">
                <span>Licorera La Bodega</span>
                <h1>Acceso de clientes</h1>
                <p>Entra a tu cuenta para revisar pedidos, comprobantes y datos de perfil desde el portal oficial.</p>

                <div class="s4-auth-hero-note">
                    <strong>Compra con confianza</strong>
                    <span>Una experiencia clara, moderna y segura para clientes de La Bodega.</span>
                </div>
            </aside>

            <section class="s4-auth-card">
                <div class="s4-auth-card-title">
                    <span>Bienvenido</span>
                    <h2>Bienvenido a La Bodega</h2>
                    <p>Ingresa con tu correo y contrasena para continuar.</p>
                </div>

                @if (TempData["RegisterSuccess"] is string msg && !string.IsNullOrWhiteSpace(msg))
                {
                    <div class="alert alert-success s4-auth-alert" role="alert">@msg</div>
                }

                <form asp-controller="Account" asp-action="Login" method="post" novalidate="novalidate">
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="control-group mb-3 s4-auth-field">
                        <label asp-for="Email" class="text-body"></label>
                        <input asp-for="Email" class="form-control" placeholder="ejemplo@correo.com" />
                        <span asp-validation-for="Email" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-3 s4-auth-field">
                        <label asp-for="Password" class="text-body"></label>
                        <input asp-for="Password" class="form-control" placeholder="Tu contrasena" />
                        <span asp-validation-for="Password" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-3 s4-auth-inline-link">
                        <a asp-controller="Account" asp-action="ForgotPassword" class="text-primary small font-weight-bold s4-auth-link">Olvidaste tu contrasena?</a>
                    </div>

                    <div class="control-group mb-4 s4-auth-check">
                        <div class="custom-control custom-checkbox">
                            <input asp-for="RememberMe" type="checkbox" class="custom-control-input" id="customCheck1">
                            <label class="custom-control-label text-secondary" for="customCheck1">Recordarme en este equipo</label>
                        </div>
                    </div>

                    <div class="s4-auth-actions">
                        <button class="btn btn-primary btn-block px-4 py-2 s4-auth-primary" type="submit">INGRESAR</button>
                    </div>

                    <div class="mt-3 text-center s4-auth-switch">
                        <span class="text-body small">No tenes cuenta?</span>
                        <a class="text-primary small font-weight-bold s4-auth-link" asp-controller="Account" asp-action="Register">Registrate</a>
                    </div>
                </form>

                <div class="mt-3 text-center s4-auth-demo-note">
                    <p class="text-muted mb-0 small">
                        Demo: <span class="font-weight-bold">admin@distribuidorajj.com</span> / <span class="font-weight-bold">1234</span>
                    </p>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
