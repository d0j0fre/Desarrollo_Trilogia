@model Proyecto_Final.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="s4-auth-page s4-auth-page--clean">
    <div class="container">
        <nav class="s4-auth-breadcrumb">
            <a asp-controller="Home" asp-action="Index">Inicio</a>
            <span>Iniciar sesión</span>
        </nav>

        <div class="s4-auth-panel s4-auth-panel--login">
            <div class="s4-auth-brand-strip">
                <div class="s4-auth-brand-mark">
                    <img src="~/brand/logo-icon.png"
                         asp-append-version="true"
                         class="s4-auth-brand-logo"
                         alt="Supermercado Mayoreo" />
                </div>
                <div class="s4-auth-brand-copy">
                    <span class="s4-auth-brand-name">Supermercado Mayoreo</span>
                    <small class="s4-auth-brand-subtitle">Licorera - Distribuidora</small>
                    <h1>Iniciar sesión</h1>
                    <p>Accede a pedidos, comprobantes y perfil desde tu cuenta.</p>
                </div>
            </div>

            <section class="s4-auth-card s4-auth-card--login s4-auth-card--clean">
                <div class="s4-auth-card-title">
                    <span>Acceso seguro</span>
                    <h2>Bienvenido de nuevo</h2>
                    <p>Ingresa tus datos para continuar.</p>
                </div>

                @if (TempData["RegisterSuccess"] is string msg && !string.IsNullOrWhiteSpace(msg))
                {
                    <div class="alert alert-success s4-auth-alert" role="alert">@msg</div>
                }

                <form asp-controller="Account" asp-action="Login" method="post" novalidate="novalidate">
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="control-group mb-3 s4-auth-field">
                        <label asp-for="Email" class="text-body"></label>
                        <input asp-for="Email" class="form-control" placeholder="ejemplo@correo.com" />
                        <span asp-validation-for="Email" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-3 s4-auth-field">
                        <label asp-for="Password" class="text-body"></label>
                        <input asp-for="Password" class="form-control" placeholder="Tu contraseña" />
                        <span asp-validation-for="Password" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-3 s4-auth-inline-link">
                        <a asp-controller="Account" asp-action="ForgotPassword" class="text-primary small font-weight-bold s4-auth-link">¿Olvidaste tu contraseña?</a>
                    </div>

                    <div class="control-group mb-4 s4-auth-check">
                        <div class="custom-control custom-checkbox">
                            <input asp-for="RememberMe" type="checkbox" class="custom-control-input" id="customCheck1">
                            <label class="custom-control-label text-secondary" for="customCheck1">Recordarme en este equipo</label>
                        </div>
                    </div>

                    <div class="s4-auth-actions">
                        <button class="btn btn-primary btn-block px-4 py-2 s4-auth-primary" type="submit">INGRESAR</button>
                    </div>

                    <div class="mt-3 text-center s4-auth-switch">
                        <span class="text-body small">¿No tenés cuenta?</span>
                        <a class="text-primary small font-weight-bold s4-auth-link" asp-controller="Account" asp-action="Register">Registrate</a>
                    </div>
                </form>

            </section>

            <div class="s4-auth-meta-row">
                <span><i class="fa fa-shield-alt"></i> Sesión protegida</span>
                <span><i class="fa fa-receipt"></i> Pedidos y comprobantes</span>
                <span><i class="fa fa-user-circle"></i> Portal del cliente</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
