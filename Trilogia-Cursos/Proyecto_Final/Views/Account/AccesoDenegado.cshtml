@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 mb-5 text-center" style="min-height: 50vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
    <i class="fa fa-lock text-danger" style="font-size: 5rem; margin-bottom: 20px;"></i>
    <h1 class="display-4 font-weight-bold text-dark">403</h1>
    <h3 class="text-uppercase" style="color: #333;">Acceso Restringido</h3>
    <p class="text-muted mt-2 mb-4" style="font-size: 1.1rem;">
        No cuentas con los permisos necesarios para visualizar este módulo.
    </p>
    <a asp-controller="Home" asp-action="Index" class="btn shadow-sm" style="background-color: #D4AF37; color: #212529; font-weight: bold; padding: 10px 30px;">
        Volver al Inicio
    </a>
</div>