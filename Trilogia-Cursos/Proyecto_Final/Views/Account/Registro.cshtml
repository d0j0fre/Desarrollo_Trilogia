@model Proyecto_Final.Models.RegistroViewModel

@{
    ViewData["Title"] = "Registro";
}

<div class="s4-auth-page s4-auth-page--clean">
    <div class="container">
        <nav class="s4-auth-breadcrumb">
            <a asp-controller="Home" asp-action="Index">Inicio</a>
            <a asp-controller="Account" asp-action="Login">Iniciar sesión</a>
            <span>Registro</span>
        </nav>

        <div class="s4-auth-panel s4-auth-panel--register">
            <div class="s4-auth-brand-strip">
                <div class="s4-auth-brand-mark">LB</div>
                <div>
                    <span>Licorera La Bodega</span>
                    <h1>Crea tu cuenta</h1>
                    <p>Compra más rápido y consulta tus pedidos desde el portal del cliente.</p>
                </div>
            </div>

            <section class="s4-auth-card s4-auth-card--register s4-auth-card--clean">
                <div class="s4-auth-card-title">
                    <span>Nueva cuenta</span>
                    <h2>Registrate en La Bodega</h2>
                    <p>Completa tus datos para empezar.</p>
                </div>

                <form asp-controller="Account" asp-action="Register" method="post" novalidate="novalidate">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="control-group mb-3 s4-auth-field">
                        <label asp-for="FullName" class="text-body"></label>
                        <input asp-for="FullName" class="form-control" placeholder="Tu nombre completo" />
                        <span asp-validation-for="FullName" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-3 s4-auth-field">
                        <label asp-for="Email" class="text-body"></label>
                        <input asp-for="Email" class="form-control" placeholder="ejemplo@correo.com" />
                        <span asp-validation-for="Email" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-3 s4-auth-field">
                        <label asp-for="Password" class="text-body"></label>
                        <input asp-for="Password" class="form-control" placeholder="Crea una contraseña" />
                        <span asp-validation-for="Password" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-4 s4-auth-field">
                        <label asp-for="ConfirmPassword" class="text-body"></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Repetí la contraseña" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger help-block"></span>
                    </div>

                    <div class="control-group mb-4 s4-auth-check">
                        <div class="custom-control custom-checkbox">
                            <input asp-for="AcceptTerms" type="checkbox" class="custom-control-input" id="termsCheck">
                            <label class="custom-control-label text-secondary" for="termsCheck">
                                Acepto los términos y condiciones
                            </label>
                        </div>
                        <span asp-validation-for="AcceptTerms" class="text-danger help-block"></span>
                    </div>

                    <div class="s4-auth-actions">
                        <button class="btn btn-primary btn-block px-4 py-2 s4-auth-primary" type="submit">CREAR CUENTA</button>
                    </div>

                    <div class="mt-3 text-center s4-auth-switch">
                        <span class="text-body small">¿Ya tenés cuenta?</span>
                        <a class="text-primary small font-weight-bold s4-auth-link" asp-controller="Account" asp-action="Login">Inicia sesión</a>
                    </div>
                </form>
            </section>

            <div class="s4-auth-meta-row">
                <span><i class="fa fa-shopping-basket"></i> Compra en línea</span>
                <span><i class="fa fa-box"></i> Historial de pedidos</span>
                <span><i class="fa fa-file-invoice"></i> Comprobantes</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
