@using Proyecto_Final.Models.Admin
@model CashSettlementFormViewModel
@{
    ViewData["Title"] = "Liquidar cobros";
    var prep = ViewBag.Prepare as CashSettlementPrepareViewModel;
    var esperadoTotal = Model.EsperadoEfectivo + Model.EsperadoOtros;
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page">
    <div class="row px-xl-5">
        <div class="col-lg-8 offset-lg-2">
            <div class="admin-page-header d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="mb-2">Liquidar cobros — Ruta @Model.RutaCodigo</h2>
                    <p class="mb-0">Registra el efectivo y los comprobantes entregados por el chofer.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary mt-2 mt-md-0"><i class="fa fa-arrow-left mr-2"></i>Volver</a>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 mb-2">
                    <div class="admin-table-wrapper p-3 text-center">
                        <div class="text-muted small">Esperado en efectivo</div>
                        <div class="h4 mb-0">@Model.EsperadoEfectivo.ToString("N2")</div>
                    </div>
                </div>
                <div class="col-md-4 mb-2">
                    <div class="admin-table-wrapper p-3 text-center">
                        <div class="text-muted small">Esperado otros medios</div>
                        <div class="h4 mb-0">@Model.EsperadoOtros.ToString("N2")</div>
                    </div>
                </div>
                <div class="col-md-4 mb-2">
                    <div class="admin-table-wrapper p-3 text-center">
                        <div class="text-muted small">Total esperado</div>
                        <div class="h4 mb-0">@esperadoTotal.ToString("N2")</div>
                    </div>
                </div>
            </div>

            <div class="admin-table-wrapper p-4">
                <form asp-action="Liquidate" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <input type="hidden" asp-for="RutaId" />
                    <input type="hidden" asp-for="RutaCodigo" />
                    <input type="hidden" asp-for="EsperadoEfectivo" />
                    <input type="hidden" asp-for="EsperadoOtros" />

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="MontoEfectivoRecibido"></label>
                            <input asp-for="MontoEfectivoRecibido" type="number" step="0.01" min="0" class="form-control" />
                            <span asp-validation-for="MontoEfectivoRecibido" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="MontoComprobantes"></label>
                            <input asp-for="MontoComprobantes" type="number" step="0.01" min="0" class="form-control" />
                            <span asp-validation-for="MontoComprobantes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Observaciones"></label>
                        <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                    </div>

                    <h6 class="mt-3 mb-2">Detalle de comprobantes (opcional)</h6>
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <select name="Comprobantes[@i].Tipo" class="form-control">
                                    <option value="">— Tipo —</option>
                                    <option value="SINPE">SINPE</option>
                                    <option value="Transferencia">Transferencia</option>
                                    <option value="Depósito">Depósito</option>
                                    <option value="Cheque">Cheque</option>
                                    <option value="Otro">Otro</option>
                                </select>
                            </div>
                            <div class="form-group col-md-5">
                                <input name="Comprobantes[@i].Referencia" class="form-control" placeholder="Referencia" />
                            </div>
                            <div class="form-group col-md-3">
                                <input name="Comprobantes[@i].Monto" type="number" step="0.01" min="0" value="0" class="form-control" placeholder="Monto" />
                            </div>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary"><i class="fa fa-save mr-2"></i>Registrar liquidación</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </form>
            </div>

            @if (prep != null && prep.Pedidos.Any())
            {
                <div class="admin-table-wrapper mt-4">
                    <div class="p-4 border-bottom"><h5 class="mb-0">Pedidos entregados</h5></div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="thead-light">
                                <tr><th>#</th><th>Cliente</th><th>Método de pago</th><th class="text-right">Total</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var p in prep.Pedidos)
                                {
                                    <tr>
                                        <td class="font-weight-bold">@p.PedidoId</td>
                                        <td>@p.Cliente</td>
                                        <td>@p.MetodoPago</td>
                                        <td class="text-right">@p.Total.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
