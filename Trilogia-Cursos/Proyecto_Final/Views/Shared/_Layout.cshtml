@using Microsoft.AspNetCore.Http
@using Proyecto_Final.Services
@inject AdminDbService AdminDbService
@{
    const string SiteBrandName = "Supermercado Mayoreo";
    const string SiteBrandSubtitle = "Licorera - Distribuidora";
    var pageTitle = ViewData["Title"]?.ToString();
    var documentTitle = string.IsNullOrWhiteSpace(pageTitle)
        ? SiteBrandName
        : $"{pageTitle} - {SiteBrandName}";
}
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8">
    <title>@documentTitle</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="supermercado, mayoreo, licorera, distribuidora, licores, whisky, vinos, cervezas, ron, vodka" name="keywords">
    <meta content="Supermercado Mayoreo - Licorera y distribuidora" name="description">

    <link href="@Url.Content("~/brand/favicon.ico")?v=sm-1" rel="icon" sizes="any">
    <link href="@Url.Content("~/brand/favicon-32x32.png")?v=sm-1" rel="icon" type="image/png" sizes="32x32">
    <link href="@Url.Content("~/brand/apple-touch-icon.png")?v=sm-1" rel="apple-touch-icon" sizes="180x180">
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="~/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
    <link href="~/css/custom-theme.css" rel="stylesheet">
    <link href="~/css/ui-modern-2027.css" rel="stylesheet">
    <link href="~/css/sprint3-ui-polish.css" rel="stylesheet">
    <link href="~/css/sprint3-modal.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/sprint4-frontend-polish.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/brand-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/brand-overrides.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>
    @{
        var userName = Context.Session.GetString("UserFullName");
        var userRole = Context.Session.GetString("UserRole");
        var isLoggedIn = !string.IsNullOrWhiteSpace(Context.Session.GetString("UserEmail"));
        var isAdmin = isLoggedIn && string.Equals(userRole, "Administrador", StringComparison.OrdinalIgnoreCase);
        var isSellerOrStaff = isLoggedIn && (
            string.Equals(userRole, "Administrador", StringComparison.OrdinalIgnoreCase)
            || string.Equals(userRole, "Empleado", StringComparison.OrdinalIgnoreCase)
            || string.Equals(userRole, "Vendedor", StringComparison.OrdinalIgnoreCase));
        var isEmployeePortalUser = isLoggedIn && (
            string.Equals(userRole, "Empleado", StringComparison.OrdinalIgnoreCase)
            || string.Equals(userRole, "Vendedor", StringComparison.OrdinalIgnoreCase));
        var isClient = isLoggedIn && string.Equals(userRole, "Cliente", StringComparison.OrdinalIgnoreCase);
        var categoriasLayout = await AdminDbService.GetStoreCategoriesAsync();
    }

    <div class="container-fluid topbar">
        <div class="row align-items-center py-2 px-xl-5">
            <div class="col-lg-6 d-none d-lg-block">
                <div class="d-inline-flex align-items-center flex-wrap">
                    <small class="text-light"><i class="fa fa-map-marker-alt mr-2 text-primary"></i>San José, Costa Rica</small>
                    <small class="px-2 text-light">|</small>
                    <small class="text-light"><i class="fa fa-shield-alt mr-2 text-primary"></i>Compra segura y catálogo actualizado</small>
                </div>
            </div>

            <div class="col-lg-6 text-center text-lg-right">
                @if (isLoggedIn)
                {
                    <div class="user-panel float-lg-right">
                        <a asp-controller="Profile" asp-action="Edit" class="text-decoration-none text-reset">
                            <div class="text-left mr-1">
                                <p class="user-panel__name">
                                    <i class="fa fa-user mr-1 text-primary"></i>@userName
                                </p>
                                <p class="user-panel__role">@userRole</p>
                            </div>
                        </a>

                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary logout-btn">
                                <i class="fa fa-sign-out-alt mr-1"></i>Cerrar sesión
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="container-fluid bg-dark mb-30 modern-nav-shell">
        <div class="row px-xl-5">
            <div class="col-lg-2 d-none d-lg-block">
                <a class="btn d-flex align-items-center justify-content-between bg-primary w-100 header-categories-button" data-toggle="collapse" href="#navbar-vertical">
                    <h6 class="text-dark m-0"><i class="fa fa-bars mr-2"></i>Categorías</h6>
                    <i class="fa fa-angle-down text-dark"></i>
                </a>

                <nav class="collapse position-absolute navbar navbar-vertical navbar-light align-items-start p-0 bg-light header-categories-panel" id="navbar-vertical">
                    <div class="navbar-nav w-100">
                        @foreach (var categoria in categoriasLayout)
                        {
                            <a asp-controller="Home" asp-action="Shop" asp-route-categoria="@categoria" class="nav-item nav-link">@categoria</a>
                        }
                    </div>
                </nav>
            </div>

            <div class="col-lg-10">
                <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-3 py-lg-0 px-0 brand-navbar-shell">
                    <a asp-controller="Home" asp-action="Index" class="brand-navbar text-decoration-none" aria-label="@SiteBrandName">
                        <span class="brand-navbar__mark" aria-hidden="true">
                            <img class="brand-navbar__icon" src="@Url.Content("~/brand/logo-icon.png")" alt="" onerror="this.style.display='none';" />
                            <span class="brand-navbar__initials">SM</span>
                        </span>
                        <span class="brand-navbar__copy">
                            <span class="brand-navbar__name">@SiteBrandName</span>
                            <span class="brand-navbar__subtitle">@SiteBrandSubtitle</span>
                        </span>
                    </a>

                    <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse justify-content-end" id="navbarCollapse">
                        <div class="navbar-nav ml-lg-auto py-0 main-nav-clean main-nav-2027">
                            <a asp-controller="Home" asp-action="Index" class="nav-item nav-link"><i class="fa fa-home mr-1"></i>Inicio</a>
                            <a asp-controller="Home" asp-action="Shop" class="nav-item nav-link"><i class="fa fa-store mr-1"></i>Tienda</a>
                            <a asp-controller="Cart" asp-action="Index" class="nav-item nav-link"><i class="fa fa-shopping-cart mr-1"></i>Carrito</a>

                            @if (isClient)
                            {
                                <a asp-controller="ClientPortal" asp-action="Index" class="nav-item nav-link">
                                    <i class="fa fa-clipboard-list mr-1"></i>Mis pedidos
                                </a>
                            }

                            @if (isEmployeePortalUser)
                            {
                                <a asp-controller="EmployeePortal" asp-action="Index" class="nav-item nav-link nav-highlight">
                                    <i class="fa fa-id-badge mr-1"></i>Mi portal
                                </a>
                            }

                            @if (isSellerOrStaff)
                            {
                                <a asp-controller="SellerOrders" asp-action="Index" class="nav-item nav-link nav-highlight">
                                    <i class="fa fa-mobile-alt mr-1"></i>Venta móvil
                                </a>
                            }

                            @if (isAdmin)
                            {
                                <div class="nav-item dropdown admin-nav-dropdown">
                                    <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                                        <i class="fa fa-th-large mr-1"></i>Operación
                                    </a>
                                    <div class="dropdown-menu admin-dropdown-menu rounded-0 border-0 m-0">
                                        <a asp-controller="Admin" asp-action="Index" class="dropdown-item"><i class="fa fa-chart-line"></i> Dashboard</a>
                                        <a asp-controller="Inventory" asp-action="Index" class="dropdown-item"><i class="fa fa-boxes"></i> Inventario</a>
                                        <a asp-controller="Inventory" asp-action="Movements" class="dropdown-item"><i class="fa fa-exchange-alt"></i> Movimientos</a>
                                        <a asp-controller="OrdersAdmin" asp-action="Index" class="dropdown-item"><i class="fa fa-clipboard-list"></i> Pedidos</a>
                                        <a asp-controller="Billing" asp-action="Index" class="dropdown-item"><i class="fa fa-file-invoice-dollar"></i> Facturación</a>
                                    </div>
                                </div>

                                <div class="nav-item dropdown admin-nav-dropdown">
                                    <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                                        <i class="fa fa-users-cog mr-1"></i>Clientes
                                    </a>
                                    <div class="dropdown-menu admin-dropdown-menu rounded-0 border-0 m-0">
                                        <a asp-controller="Clients" asp-action="Index" class="dropdown-item"><i class="fa fa-users"></i> Clientes</a>
                                        <a asp-controller="Credits" asp-action="Index" class="dropdown-item"><i class="fa fa-credit-card"></i> Créditos</a>
                                        <a asp-controller="Consultations" asp-action="Index" class="dropdown-item"><i class="fa fa-comments"></i> Consultas</a>
                                        <a asp-controller="Audit" asp-action="Index" class="dropdown-item"><i class="fa fa-history"></i> Auditoría</a>
                                    </div>
                                </div>

                                <div class="nav-item dropdown admin-nav-dropdown">
                                    <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                                        <i class="fa fa-user-tie mr-1"></i>Personal
                                    </a>
                                    <div class="dropdown-menu admin-dropdown-menu rounded-0 border-0 m-0">
                                        <a asp-controller="Employees" asp-action="Index" class="dropdown-item"><i class="fa fa-id-badge"></i> Empleados</a>
                                        <a asp-controller="Employees" asp-action="LeaveRequests" class="dropdown-item"><i class="fa fa-calendar-check"></i> Solicitudes</a>
                                    </div>
                                </div>

                                <div class="nav-item dropdown admin-nav-dropdown">
                                    <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                                        <i class="fa fa-shield-alt mr-1"></i>Seguridad
                                    </a>
                                    <div class="dropdown-menu admin-dropdown-menu rounded-0 border-0 m-0">
                                        <a asp-controller="Roles" asp-action="Index" class="dropdown-item"><i class="fa fa-user-shield"></i> Roles</a>
                                        <a asp-controller="Permissions" asp-action="Index" class="dropdown-item"><i class="fa fa-key"></i> Permisos</a>
                                    </div>
                                </div>
                            }

                            @if (!isLoggedIn)
                            {
                                <a asp-controller="Account" asp-action="Login" class="nav-item nav-link text-primary font-weight-bold"><i class="fa fa-user mr-1"></i>Iniciar sesión</a>
                                <a asp-controller="Account" asp-action="Register" class="nav-item nav-link"><i class="fa fa-user-plus mr-1"></i>Registro</a>
                            }
                        </div>
                    </div>
                </nav>
            </div>
        </div>
    </div>

    <main role="main">
        @if (TempData["LoginSuccess"] is string loginSuccess && !string.IsNullOrWhiteSpace(loginSuccess))
        {
            <div class="container mt-3"><div class="alert alert-success">@loginSuccess</div></div>
        }
        @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="container mt-3"><div class="alert alert-success">@successMessage</div></div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="container mt-3"><div class="alert alert-danger">@errorMessage</div></div>
        }

        @RenderBody()
    </main>

    <footer class="container-fluid s3-footer mt-5 pt-5">
        <div class="row px-xl-5 pb-4">
            <div class="col-lg-4 col-md-6">
                <a asp-controller="Home" asp-action="Index" class="s3-footer__brand brand-footer text-decoration-none">
                    <span class="brand-footer__mark"><i class="fa fa-store text-primary"></i></span>
                    <span class="brand-footer__copy">
                        <span class="brand-footer__name">@SiteBrandName</span>
                        <small>@SiteBrandSubtitle</small>
                    </span>
                </a>
                <p class="s3-footer__text mb-3">
                    Sistema web para consulta de productos, gestion de pedidos, venta movil, inventario, facturacion y administracion general del supermercado y distribuidora.
                </p>
                <a asp-controller="Home" asp-action="Contact" class="btn btn-primary btn-sm">
                    <i class="fa fa-envelope mr-1"></i>Ir a contacto
                </a>
            </div>

            <div class="col-lg-2 col-md-6">
                <h6 class="s3-footer__title">Navegación</h6>
                <ul class="s3-footer__list">
                    <li><a asp-controller="Home" asp-action="Index"><i class="fa fa-angle-right mr-1"></i>Inicio</a></li>
                    <li><a asp-controller="Home" asp-action="Shop"><i class="fa fa-angle-right mr-1"></i>Tienda</a></li>
                    <li><a asp-controller="Cart" asp-action="Index"><i class="fa fa-angle-right mr-1"></i>Carrito</a></li>
                    <li><a asp-controller="Home" asp-action="Contact"><i class="fa fa-angle-right mr-1"></i>Contacto</a></li>
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <h6 class="s3-footer__title">Categorías</h6>
                <ul class="s3-footer__list">
                    @foreach (var categoria in categoriasLayout.Take(6))
                    {
                        <li>
                            <a asp-controller="Home" asp-action="Shop" asp-route-categoria="@categoria">
                                <i class="fa fa-angle-right mr-1"></i>@categoria
                            </a>
                        </li>
                    }
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <h6 class="s3-footer__title">Contacto</h6>
                <div class="s3-footer__contact-item">
                    <i class="fa fa-map-marker-alt"></i>
                    <span>San José, Costa Rica</span>
                </div>
                <div class="s3-footer__contact-item">
                    <i class="fa fa-envelope"></i>
                    <span>contacto@supermercadomayoreo.cr</span>
                </div>
                <div class="s3-footer__contact-item">
                    <i class="fa fa-phone-alt"></i>
                    <span>+506 2222-2222</span>
                </div>
                <div class="s3-footer__contact-item">
                    <i class="fa fa-clock"></i>
                    <span>Lunes a sábado · 8:00 a.m. - 6:00 p.m.</span>
                </div>
            </div>
        </div>

        <div class="row mx-xl-5 py-4 s3-footer__bottom">
            <div class="col-md-6 px-xl-0">
                <p class="mb-md-0 text-center text-md-left">&copy; @DateTime.Now.Year <a class="text-primary" href="#">@SiteBrandName</a>. Todos los derechos reservados.</p>
            </div>
            <div class="col-md-6 px-xl-0 text-center text-md-right">
                <img class="img-fluid s3-footer__payments" src="@Url.Content("~/img/payments.png")" alt="Métodos de pago">
            </div>
        </div>
    </footer>

    <a href="#" class="btn btn-primary back-to-top"><i class="fa fa-angle-double-up"></i></a>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/js/main.js"></script>
    <script src="~/js/sprint3-modal.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
