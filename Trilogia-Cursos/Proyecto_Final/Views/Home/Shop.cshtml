@model Proyecto_Final.Models.Store.ShopViewModel
@{
    ViewData["Title"] = Model.Titulo;
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid store-hero mb-4">
    <div class="row px-xl-5 py-4">
        <div class="col-12">
            <div class="store-banner">
                <div>
                    <span class="store-eyebrow">Catálogo disponible</span>
                    <h1 class="store-title">@Model.Titulo</h1>
                    <p class="store-copy">
                        Explora el inventario activo con una presentación clara, consistente y fácil de navegar.
                    </p>
                </div>

                <form asp-controller="Home" asp-action="Shop" method="get" class="store-search-form">
                    <input type="hidden" name="categoria" value="@Model.Categoria" />
                    <div class="input-group">
                        <input type="text" name="buscar" value="@Model.Buscar" class="form-control" placeholder="Buscar producto..." />
                        <div class="input-group-append">
                            <button class="btn btn-primary px-4" type="submit"><i class="fa fa-search mr-2"></i>Buscar</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid pb-5">
    <div class="row px-xl-5">
        <div class="col-12 mb-4">
            <div class="store-filters">
                <a asp-controller="Home" asp-action="Shop" class="filter-chip @(string.IsNullOrWhiteSpace(Model.Categoria) ? "active" : "")">Todos</a>
                @foreach (var categoria in Model.Categorias)
                {
                    <a asp-controller="Home" asp-action="Shop" asp-route-categoria="@categoria" class="filter-chip @(string.Equals(Model.Categoria, categoria, StringComparison.OrdinalIgnoreCase) ? "active" : "")">@categoria</a>
                }
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        @if (Model.Productos == null || Model.Productos.Count == 0)
        {
            <div class="col-12"><div class="store-empty"><h4>No se encontraron productos</h4><p>Prueba con otra categoría o con otro texto en la búsqueda.</p></div></div>
        }
        else
        {
            @foreach (var producto in Model.Productos)
            {
                var claseStock = producto.Stock <= 0 ? "out" : producto.Stock <= 5 ? "low" : "ok";
                var imagen = string.IsNullOrWhiteSpace(producto.ImagenUrl) ? Url.Content("~/img/whisky-premium.webp") : Url.Content(producto.ImagenUrl);
                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 pb-4 d-flex align-items-stretch">
                    <div class="product-card-v2 w-100">
                        <div class="product-card-v2__image-wrap"><img src="@imagen" alt="@producto.Nombre" class="product-card-v2__image" /></div>
                        <div class="product-card-v2__body d-flex flex-column">
                            <span class="product-card-v2__category">@producto.Categoria</span>
                            <h5 class="product-card-v2__title">@producto.Nombre</h5>
                            <p class="product-card-v2__desc">@(string.IsNullOrWhiteSpace(producto.Descripcion) ? "Producto disponible dentro del catálogo activo." : producto.Descripcion)</p>
                            <div class="mt-auto">
                                <div class="product-card-v2__footer mb-3">
                                    <div>
                                        <div class="product-card-v2__price">₡@producto.Precio.ToString("N0")</div>
                                        <small class="product-card-v2__stock @claseStock">@(producto.Stock <= 0 ? "Agotado" : producto.Stock <= 5 ? "Stock bajo" : "Disponible") · Stock: @producto.Stock</small>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap">
                                    <a asp-controller="Home" asp-action="Detail" asp-route-id="@producto.ProductoId" class="btn btn-primary btn-sm mr-2 mb-2">Ver detalle</a>
                                    @if (producto.Stock > 0)
                                    {
                                        <form asp-controller="Cart" asp-action="Add" method="post" class="mb-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productoId" value="@producto.ProductoId" />
                                            <input type="hidden" name="cantidad" value="1" />
                                            <button type="submit" class="btn btn-primary btn-sm"><i class="fa fa-shopping-cart mr-1"></i>Comprar</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-secondary btn-sm mb-2" disabled>Agotado</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
