@model Proyecto_Final.Models.Store.HomeFeaturedViewModel
@{
    ViewData["Title"] = "Inicio";

    var categorias = new[]
    {
        new { Nombre = "Whisky", Texto = "Etiquetas premium", Imagen = "~/img/CAT-Whisky.png", Icono = "fa-glass-cheers" },
        new { Nombre = "Vino", Texto = "Tintos y espumantes", Imagen = "~/img/CAT-Vino.png", Icono = "fa-wine-bottle" },
        new { Nombre = "Ron", Texto = "Nacionales e importados", Imagen = "~/img/CAT- Ron.png", Icono = "fa-cocktail" },
        new { Nombre = "Tequila", Texto = "Blanco y reposado", Imagen = "~/img/CAT-Tequila.webp", Icono = "fa-star" },
        new { Nombre = "Vodka", Texto = "Clásicos y sabores", Imagen = "~/img/CAT-Vodka.webp", Icono = "fa-snowflake" },
        new { Nombre = "Cerveza", Texto = "Lager, artesanal y packs", Imagen = "~/img/CAT-Cerveza.png", Icono = "fa-beer" }
    };
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
    <link href="~/css/sprint3-storefront-polish.css" rel="stylesheet" />
}

<div class="s3-storefront-page">
    <section class="s3-home-hero">
        <div class="s3-home-hero__content">
            <span class="s3-home-eyebrow">
                <i class="fa fa-store"></i>
                Licorera La Bodega
            </span>

            <h1>Comprá licores, vinos y cervezas con una experiencia más clara y profesional.</h1>

            <p>
                Catálogo organizado, productos destacados, control de inventario y una navegación pensada para clientes, vendedores y administradores.
            </p>

            <div class="s3-home-hero__actions">
                <a asp-controller="Home" asp-action="Shop" class="btn btn-primary btn-lg">
                    <i class="fa fa-shopping-bag mr-1"></i>Ir a la tienda
                </a>
                <a asp-controller="Home" asp-action="Shop" asp-route-categoria="Whisky" class="btn btn-outline-light btn-lg">
                    <i class="fa fa-glass-cheers mr-1"></i>Ver premium
                </a>
            </div>

            <div class="s3-home-hero__metrics">
                <div>
                    <strong>6+</strong>
                    <span>Categorías</span>
                </div>
                <div>
                    <strong>24/7</strong>
                    <span>Catálogo web</span>
                </div>
                <div>
                    <strong>CR</strong>
                    <span>Datos locales</span>
                </div>
            </div>
        </div>

        <div class="s3-home-hero__visual">
            <div class="s3-hero-product-card s3-hero-product-card--main">
                <img src="@Url.Content("~/img/whisky-premium.webp")" alt="Whisky premium" />
                <div>
                    <span>Selección destacada</span>
                    <h3>Whisky Premium</h3>
                    <p>Productos con mejor presentación, stock visible y acceso directo al detalle.</p>
                    <a asp-controller="Home" asp-action="Shop" asp-route-categoria="Whisky">Explorar categoría</a>
                </div>
            </div>

            <div class="s3-hero-mini-grid">
                <a asp-controller="Home" asp-action="Shop" asp-route-buscar="Combo" class="s3-hero-mini-card">
                    <img src="@Url.Content("~/img/OFER-Combo.webp")" alt="Combos" />
                    <div>
                        <span>Promos</span>
                        <strong>Combos</strong>
                    </div>
                </a>

                <a asp-controller="Home" asp-action="Shop" asp-route-categoria="Vino" class="s3-hero-mini-card">
                    <img src="@Url.Content("~/img/CARR-Vino y espumantes.jpg")" alt="Vinos" />
                    <div>
                        <span>Celebraciones</span>
                        <strong>Vinos</strong>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <section class="s3-benefit-grid">
        <article class="s3-benefit-card">
            <i class="fa fa-shipping-fast"></i>
            <div>
                <h3>Entrega rápida</h3>
                <p>Cobertura sujeta a disponibilidad y operación del negocio.</p>
            </div>
        </article>

        <article class="s3-benefit-card">
            <i class="fa fa-lock"></i>
            <div>
                <h3>Compra segura</h3>
                <p>Validación de stock y precios antes de finalizar pedidos.</p>
            </div>
        </article>

        <article class="s3-benefit-card">
            <i class="fa fa-certificate"></i>
            <div>
                <h3>Inventario controlado</h3>
                <p>Productos activos administrados desde el panel interno.</p>
            </div>
        </article>

        <article class="s3-benefit-card">
            <i class="fa fa-headset"></i>
            <div>
                <h3>Soporte</h3>
                <p>Consultas y pedidos conectados con la gestión administrativa.</p>
            </div>
        </article>
    </section>

    <section class="s3-home-section">
        <div class="s3-home-section__head">
            <div>
                <span class="s3-home-eyebrow"><i class="fa fa-layer-group"></i>Categorías</span>
                <h2>Encontrá más rápido lo que buscás</h2>
            </div>
            <a asp-controller="Home" asp-action="Shop" class="btn btn-outline-dark">
                Ver todo el catálogo
            </a>
        </div>

        <div class="s3-category-grid">
            @foreach (var categoria in categorias)
            {
                <a class="s3-category-card" asp-controller="Home" asp-action="Shop" asp-route-categoria="@categoria.Nombre">
                    <div class="s3-category-card__image">
                        <img src="@Url.Content(categoria.Imagen)" alt="@categoria.Nombre" />
                    </div>
                    <div>
                        <span><i class="fa @categoria.Icono"></i>@categoria.Nombre</span>
                        <p>@categoria.Texto</p>
                    </div>
                    <i class="fa fa-arrow-right s3-category-card__arrow"></i>
                </a>
            }
        </div>
    </section>

    <section class="s3-home-section">
        <div class="s3-home-section__head">
            <div>
                <span class="s3-home-eyebrow"><i class="fa fa-star"></i>Destacados</span>
                <h2>Productos recomendados</h2>
            </div>
            <a asp-controller="Home" asp-action="Shop" class="btn btn-primary">
                <i class="fa fa-store mr-1"></i>Comprar ahora
            </a>
        </div>

        @if (Model?.ProductosDestacados != null && Model.ProductosDestacados.Any())
        {
            <div class="s3-product-grid s3-product-grid--home">
                @foreach (var item in Model.ProductosDestacados.Take(4))
                {
                    var imagen = string.IsNullOrWhiteSpace(item.ImagenUrl) ? Url.Content("~/img/whisky-premium.webp") : Url.Content(item.ImagenUrl);
                    var stockClass = item.Stock <= 0 ? "out" : item.Stock <= 5 ? "low" : "ok";

                    <article class="s3-product-card">
                        <a asp-controller="Home" asp-action="Detail" asp-route-id="@item.ProductoId" class="s3-product-card__image">
                            <img src="@imagen" alt="@item.Nombre" />
                        </a>

                        <div class="s3-product-card__body">
                            <span class="s3-product-card__category">@item.Categoria</span>
                            <h3>@item.Nombre</h3>
                            <p>@(string.IsNullOrWhiteSpace(item.Descripcion) ? "Producto disponible dentro del catálogo activo." : item.Descripcion)</p>

                            <div class="s3-product-card__footer">
                                <div>
                                    <strong>₡@item.Precio.ToString("N0")</strong>
                                    <small class="s3-stock-badge @stockClass">@item.EstadoStock</small>
                                </div>
                                <a asp-controller="Home" asp-action="Detail" asp-route-id="@item.ProductoId" class="btn btn-primary btn-sm">
                                    Ver
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="s3-empty-state">
                <i class="fa fa-box-open"></i>
                <h3>No hay productos destacados configurados</h3>
                <p>Podés asignar productos destacados desde el módulo de inventario.</p>
            </div>
        }
    </section>
</div>
