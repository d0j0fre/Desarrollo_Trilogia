@model List<Proyecto_Final.Models.Admin.WarrantyRequestViewModel>
@{
    ViewData["Title"] = "Solicitudes de garantía";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-0"><i class="fa fa-shield-alt mr-2"></i>Solicitudes de garantía</h3>
                <small>Revisión, resolución y trazabilidad de solicitudes de clientes.</small>
            </div>
            <span class="badge badge-dark">Total: @Model.Count</span>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info mb-0">No existen solicitudes de garantía registradas.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="thead-light">
                            <tr><th>#</th><th>Pedido / producto</th><th>Cliente</th><th>Solicitud</th><th>Estado</th><th>Gestión</th></tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            var terminal = item.Estado is "Aprobada" or "Rechazada";
                            <tr>
                                <td><strong>#@item.GarantiaId</strong></td>
                                <td>
                                    <strong>Pedido #@item.PedidoId</strong><br />
                                    @item.Producto
                                </td>
                                <td>
                                    @item.Cliente<br />
                                    <a asp-controller="Clients" asp-action="Details" asp-route-id="@item.UsuarioId" class="small">Ver cliente</a>
                                </td>
                                <td style="min-width:230px">
                                    <strong>@item.Motivo</strong><br />
                                    @if (!string.IsNullOrWhiteSpace(item.Descripcion)) { <span>@item.Descripcion<br /></span> }
                                    <small class="text-muted">@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</small>
                                </td>
                                <td>
                                    <span class="badge @(item.Estado == "Aprobada" ? "badge-success" : item.Estado == "Rechazada" ? "badge-danger" : item.Estado == "En revisión" ? "badge-info" : "badge-warning")">
                                        @item.Estado
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(item.Resolucion))
                                    {
                                        <p class="small mt-2 mb-0">@item.Resolucion</p>
                                    }
                                </td>
                                <td style="min-width:280px">
                                    @if (!terminal)
                                    {
                                        <form asp-action="UpdateStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="garantiaId" value="@item.GarantiaId" />
                                            <select name="estado" class="form-control form-control-sm mb-2" required>
                                                <option value="En revisión">En revisión</option>
                                                <option value="Aprobada">Aprobada</option>
                                                <option value="Rechazada">Rechazada</option>
                                            </select>
                                            <textarea name="resolucion" class="form-control form-control-sm mb-2" maxlength="1000" rows="2" placeholder="Resolución obligatoria al cerrar"></textarea>
                                            <button type="submit" class="btn btn-sm btn-primary">Actualizar</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Solicitud cerrada.</small>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
