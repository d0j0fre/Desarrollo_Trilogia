@model Proyecto_Final.Models.Admin.RolePermissionAssignmentViewModel
@{
    ViewData["Title"] = "Asignar permisos";
    var esAdministrador = Model.EsAdministrador;
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page access-admin-page permissions-admin-page">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">Permisos del rol: @Model.RolNombre</h2>
                    <p class="text-muted mb-0">
                        @Model.RolDescripcion
                    </p>
                </div>
                <a asp-controller="Permissions" asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-3">
        <div class="col-lg-4 col-md-6 pb-3">
            <div class="admin-card text-center h-100">
                <i class="fa fa-key fa-2x text-primary mb-3"></i>
                <h6 class="text-muted">Permisos asignados</h6>
                <h3 class="mb-0">@Model.TotalAsignados / @Model.TotalPermisos</h3>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 pb-3">
            <div class="admin-card text-center h-100">
                <i class="fa fa-user-shield fa-2x text-primary mb-3"></i>
                <h6 class="text-muted">Estado del rol</h6>
                @if (Model.RolActivo)
                {
                    <h3 class="mb-0">Activo</h3>
                }
                else
                {
                    <h3 class="mb-0">Inactivo</h3>
                }
            </div>
        </div>
        <div class="col-lg-4 col-md-12 pb-3">
            <div class="admin-card h-100">
                <h5 class="mb-2">Nota de seguridad</h5>
                @if (esAdministrador)
                {
                    <p class="text-muted mb-0">El rol Administrador conserva todos los permisos para evitar bloqueos del sistema.</p>
                }
                else
                {
                    <p class="text-muted mb-0">Los cambios quedarán registrados en la bitácora de auditoría.</p>
                }
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <form asp-controller="Permissions" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="perfilId" value="@Model.PerfilId" />

                @if (esAdministrador)
                {
                    <div class="alert alert-info">
                        Este rol es base del sistema. Sus permisos se muestran para consulta, pero no se modifican desde esta pantalla.
                    </div>
                }

                <div class="row">
                    @foreach (var grupo in Model.Modulos)
                    {
                        <div class="col-lg-6 col-xl-4 pb-4">
                            <div class="admin-card h-100">
                                <h5 class="mb-3">
                                    <i class="fa fa-folder-open text-primary mr-2"></i>@grupo.Modulo
                                </h5>

                                @foreach (var permiso in grupo.Permisos)
                                {
                                    <div class="border rounded p-3 mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="permiso_@permiso.PermisoId"
                                                   name="permisosSeleccionados"
                                                   value="@permiso.PermisoId"
                                                   @(permiso.Asignado ? "checked" : "")
                                                   @(esAdministrador ? "disabled" : "") />
                                            <label class="form-check-label font-weight-bold" for="permiso_@permiso.PermisoId">
                                                @permiso.Nombre
                                            </label>
                                        </div>
                                        <small class="text-muted d-block mt-1">@permiso.Descripcion</small>
                                        <small class="text-muted d-block mt-1"><strong>Código:</strong> @permiso.Codigo</small>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="admin-card d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">Guardar asignación de permisos</h5>
                        <p class="text-muted mb-0">Revise bien antes de guardar los cambios del rol.</p>
                    </div>
                    <div class="d-flex" style="gap:10px;">
                        <a asp-controller="Permissions" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        @if (!esAdministrador)
                        {
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-save mr-1"></i> Guardar permisos
                            </button>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
