@model IEnumerable<Proyecto_Final.Models.Admin.RoleListItemViewModel>
@{
    ViewData["Title"] = "Permisos por rol";
    var buscar = ViewBag.Buscar as string;
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page access-admin-page permissions-admin-page">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">Permisos por rol</h2>
                    <p class="text-muted mb-0">Seleccione un rol para asignar o revisar sus permisos del sistema.</p>
                </div>
                <a asp-controller="Roles" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fa fa-user-shield mr-1"></i> Ir a Roles
                </a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 mb-3">
        <div class="col-12">
            <form asp-controller="Permissions" asp-action="Index" method="get" class="d-flex" style="gap:8px;">
                <input type="text" name="buscar" value="@buscar"
                       class="form-control" placeholder="Buscar rol por nombre o descripción..." />
                <button type="submit" class="btn btn-dark">Buscar</button>
                @if (!string.IsNullOrWhiteSpace(buscar))
                {
                    <a asp-controller="Permissions" asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                }
            </form>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>ID</th>
                                <th>Rol</th>
                                <th>Descripción</th>
                                <th>Usuarios</th>
                                <th>Estado</th>
                                <th>Permisos</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        No se encontraron roles para administrar permisos.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.PerfilId</td>
                                        <td class="font-weight-bold">
                                            @item.Nombre
                                            @if (item.EsRolBase)
                                            {
                                                <span class="badge badge-light ml-1">Base</span>
                                            }
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Descripcion) ? "Sin descripción" : item.Descripcion)</td>
                                        <td>@item.TotalUsuarios</td>
                                        <td>
                                            @if (item.Activo)
                                            {
                                                <span class="admin-badge-soft success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="admin-badge-soft danger">Inactivo</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-controller="Permissions"
                                               asp-action="Edit"
                                               asp-route-id="@item.PerfilId"
                                               class="btn btn-sm btn-primary">
                                                <i class="fa fa-key mr-1"></i> Administrar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
