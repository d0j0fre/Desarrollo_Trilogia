@model Proyecto_Final.Models.Admin.RouteCreateViewModel
@{
    ViewData["Title"] = "Nueva ruta de entrega";
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="mb-2">Nueva ruta de entrega</h2>
                    <p class="mb-0">Agrupa pedidos por zona y asigna un chofer y un vehículo disponibles.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary mt-2 mt-md-0"><i class="fa fa-arrow-left mr-2"></i>Volver</a>
            </div>
        </div>
    </div>

    @if (!Model.HayRecursos)
    {
        <div class="row px-xl-5">
            <div class="col-12">
                <div class="alert alert-warning">
                    <i class="fa fa-exclamation-triangle mr-2"></i>
                    No hay <strong>chofer</strong> o <strong>vehículo</strong> disponible para asignar la ruta.
                    Registre o active recursos antes de crear una ruta.
                </div>
            </div>
        </div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger px-xl-5"></div>

        <div class="row px-xl-5">
            <div class="col-lg-5 mb-4">
                <div class="admin-table-wrapper p-4">
                    <h5 class="mb-3">Datos de la ruta</h5>

                    <div class="form-group">
                        <label asp-for="Zona" class="font-weight-bold">Zona</label>
                        <input asp-for="Zona" class="form-control" placeholder="Ej: GAM Heredia, Alajuela Centro" />
                        <span asp-validation-for="Zona" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ChoferUsuarioId" class="font-weight-bold">Chofer</label>
                        <select asp-for="ChoferUsuarioId" class="form-control">
                            <option value="0">-- Seleccione un chofer --</option>
                            @foreach (var ch in Model.Choferes)
                            {
                                <option value="@ch.UsuarioId">@ch.NombreCompleto (@ch.RutasAbiertas ruta(s) abierta(s))</option>
                            }
                        </select>
                        <span asp-validation-for="ChoferUsuarioId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="VehiculoId" class="font-weight-bold">Vehículo</label>
                        <select asp-for="VehiculoId" class="form-control">
                            <option value="0">-- Seleccione un vehículo --</option>
                            @foreach (var v in Model.Vehiculos)
                            {
                                <option value="@v.VehiculoId">@v.Placa - @v.Descripcion (@v.RutasAbiertas abierta(s))</option>
                            }
                        </select>
                        <span asp-validation-for="VehiculoId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Observaciones" class="font-weight-bold">Observaciones</label>
                        <textarea asp-for="Observaciones" class="form-control" rows="2" placeholder="Opcional"></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block" disabled="@(!Model.HayRecursos)">
                        <i class="fa fa-route mr-2"></i>Crear ruta
                    </button>
                </div>
            </div>

            <div class="col-lg-7 mb-4">
                <div class="admin-table-wrapper">
                    <div class="p-4 border-bottom d-flex justify-content-between align-items-center flex-wrap">
                        <h5 class="mb-0">Pedidos por asignar</h5>
                        <span class="text-muted">Seleccione los pedidos de la zona</span>
                    </div>
                    <div class="table-responsive" style="max-height: 460px; overflow-y: auto;">
                        <table class="table table-hover mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th style="width:40px;"></th>
                                    <th># Pedido</th>
                                    <th>Cliente</th>
                                    <th>Dirección</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.PedidosDisponibles.Any())
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-4">No hay pedidos pendientes de asignar.</td></tr>
                                }
                                else
                                {
                                    @foreach (var p in Model.PedidosDisponibles)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <input class="form-check-input position-static" type="checkbox"
                                                       name="PedidosSeleccionados" value="@p.PedidoId" />
                                            </td>
                                            <td class="font-weight-bold">#@p.PedidoId</td>
                                            <td>@p.Cliente</td>
                                            <td><small>@p.DireccionEntrega</small></td>
                                            <td>₡@p.Total.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
