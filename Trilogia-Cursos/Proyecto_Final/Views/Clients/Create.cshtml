@model Proyecto_Final.Models.Admin.ClientFormViewModel
@{
    ViewData["Title"] = "Crear cliente";
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">Crear cliente</h2>
                    <p class="text-muted mb-0">Registra un cliente manualmente para mantener actualizado el historial comercial.</p>
                </div>
                <a asp-controller="Clients" asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-lg-8">
            <div class="admin-card">
                <form asp-controller="Clients" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="form-group">
                        <label asp-for="NombreCompleto" class="font-weight-bold">Nombre completo <span class="text-danger">*</span></label>
                        <input asp-for="NombreCompleto" class="form-control" placeholder="Ejemplo: Cliente Comercial San José" />
                        <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Correo" class="font-weight-bold">Correo electrónico <span class="text-danger">*</span></label>
                        <input asp-for="Correo" class="form-control" placeholder="cliente@correo.com" />
                        <span asp-validation-for="Correo" class="text-danger small"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="Telefono" class="font-weight-bold">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" placeholder="8888-0000" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="form-group col-md-6">
                            <label asp-for="Contrasena" class="font-weight-bold">Contraseña <span class="text-danger">*</span></label>
                            <input asp-for="Contrasena" class="form-control" placeholder="Contraseña temporal" />
                            <span asp-validation-for="Contrasena" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Direccion" class="font-weight-bold">Dirección</label>
                        <textarea asp-for="Direccion" class="form-control" rows="3" placeholder="Dirección comercial o de entrega"></textarea>
                        <span asp-validation-for="Direccion" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="Activo" class="form-check-input" />
                        <label asp-for="Activo" class="form-check-label">Cliente activo</label>
                    </div>

                    <div class="form-group">
                        <label asp-for="MotivoInactivacion" class="font-weight-bold">Motivo de inactivación</label>
                        <textarea asp-for="MotivoInactivacion" class="form-control" rows="2" placeholder="Solo necesario si registra el cliente como inactivo"></textarea>
                        <span asp-validation-for="MotivoInactivacion" class="text-danger small"></span>
                    </div>

                    <div class="d-flex" style="gap:10px;">
                        <button type="submit" class="btn btn-primary">Guardar cliente</button>
                        <a asp-controller="Clients" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="admin-card">
                <h5 class="mb-3">Información</h5>
                <ul class="contact-list">
                    <li>El cliente se registra con el rol Cliente.</li>
                    <li>El correo debe ser único en el sistema.</li>
                    <li>Si el cliente queda inactivo, no podrá iniciar sesión.</li>
                    <li>La creación queda registrada en Auditoría.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
