@using Proyecto_Final.Models.Admin
@model AssetDetailViewModel
@{
    ViewData["Title"] = "Detalle de activo";
    string EstadoBadge(string e) => e switch { "Disponible" => "success", "Prestado" => "info", "Mantenimiento" => "warning", _ => "danger" };
    string ComodatoBadge(string e) => e switch { "Activo" => "info", "Devuelto" => "success", _ => "warning" };
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page">
    <div class="row px-xl-5">
        <div class="col-lg-8 offset-lg-2">
            <div class="admin-page-header d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="mb-2">Activo @Model.Activo.CodigoActivo</h2>
                    <p class="mb-0">@Model.Activo.Nombre</p>
                </div>
                <div class="mt-2 mt-md-0">
                    <a asp-action="Edit" asp-route-id="@Model.Activo.ActivoId" class="btn btn-outline-primary mr-2"><i class="fa fa-edit mr-2"></i>Editar</a>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fa fa-arrow-left mr-2"></i>Volver</a>
                </div>
            </div>

            <div class="admin-table-wrapper p-4 mb-4">
                <div class="row">
                    <div class="col-md-6 mb-2"><span class="text-muted small d-block">Código de activo</span><strong>@Model.Activo.CodigoActivo</strong></div>
                    <div class="col-md-6 mb-2"><span class="text-muted small d-block">Tipo</span><strong>@Model.Activo.Tipo</strong></div>
                    <div class="col-md-6 mb-2"><span class="text-muted small d-block">Estado</span><span class="admin-badge-soft @EstadoBadge(Model.Activo.Estado)">@Model.Activo.Estado</span></div>
                    <div class="col-md-6 mb-2"><span class="text-muted small d-block">Prestado a</span><strong>@(string.IsNullOrWhiteSpace(Model.Activo.ClientePrestamo) ? "—" : Model.Activo.ClientePrestamo)</strong></div>
                    <div class="col-12 mb-0"><span class="text-muted small d-block">Descripción</span><span>@(string.IsNullOrWhiteSpace(Model.Activo.Descripcion) ? "—" : Model.Activo.Descripcion)</span></div>
                </div>
            </div>

            <div class="admin-table-wrapper">
                <div class="p-4 border-bottom"><h5 class="mb-0"><i class="fa fa-handshake mr-2 text-primary"></i>Historial de comodatos</h5></div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="thead-light">
                            <tr><th>Cliente</th><th class="text-center">Asignado</th><th class="text-center">Devuelto</th><th class="text-center">Estado</th><th>Destino</th></tr>
                        </thead>
                        <tbody>
                            @if (!Model.Historial.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">Este activo no tiene comodatos registrados.</td></tr>
                            }
                            else
                            {
                                @foreach (var h in Model.Historial)
                                {
                                    <tr>
                                        <td class="font-weight-bold">@h.ClienteNombre</td>
                                        <td class="text-center">@h.FechaAsignacion.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@(h.FechaDevolucion.HasValue ? h.FechaDevolucion.Value.ToString("dd/MM/yyyy") : "—")</td>
                                        <td class="text-center"><span class="admin-badge-soft @ComodatoBadge(h.Estado)">@h.Estado</span></td>
                                        <td>@(string.IsNullOrWhiteSpace(h.DestinoDevolucion) ? "—" : h.DestinoDevolucion)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
