@model Proyecto_Final.Models.Store.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}
<section class="s4-checkout-page">
    <div class="container">
        <div class="s4-checkout-hero">
            <div>
                <span class="s4-checkout-hero__eyebrow">Compra segura</span>
                <h1>Finalizar compra</h1>
                <p>Completa los datos de entrega y revisa tu resumen antes de crear el pedido.</p>
            </div>
            <div class="s4-checkout-hero__badge">
                <i class="fa fa-shield-alt"></i>
                <span>Pedido protegido</span>
            </div>
        </div>

        <div class="s4-checkout-grid">
            <form asp-action="Checkout" method="post" id="checkoutForm" class="s4-checkout-card">
                @Html.AntiForgeryToken()
                <input type="hidden" id="savedProvincia" value="@(Model.Provincia ?? string.Empty)" />
                <input type="hidden" id="savedCanton" value="@(Model.Canton ?? string.Empty)" />
                <input type="hidden" id="savedDistrito" value="@(Model.Distrito ?? string.Empty)" />

                <div asp-validation-summary="ModelOnly" class="s4-checkout-validation text-danger"></div>

                <div class="s4-checkout-section">
                    <div class="s4-checkout-section-title">
                        <i class="fa fa-user-check"></i>
                        <div>
                            <span>Paso 1</span>
                            <h2>Datos del cliente</h2>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="CorreoElectronico"></label>
                        <input asp-for="CorreoElectronico" class="form-control" readonly />
                        <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                    </div>

                    <div class="s4-checkout-field-grid">
                        <div class="form-group">
                            <label asp-for="TipoCliente"></label>
                            <div class="btn-group-toggle s4-checkout-option-grid" data-toggle="buttons">
                                <label class="btn btn-secondary s4-checkout-option @(Model.TipoCliente == "Cliente Físico" ? "active" : "")">
                                    <input type="radio" asp-for="TipoCliente" value="Cliente Físico" autocomplete="off"> Cliente Físico
                                </label>
                                <label class="btn btn-secondary s4-checkout-option @(Model.TipoCliente == "Cliente Jurídico" ? "active" : "")">
                                    <input type="radio" asp-for="TipoCliente" value="Cliente Jurídico" autocomplete="off"> Cliente Jurídico
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label asp-for="Identificacion"></label>
                            <input asp-for="Identificacion" class="form-control" placeholder="Identificación" />
                            <span asp-validation-for="Identificacion" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="s4-checkout-note">
                        <div class="form-check">
                            <input asp-for="FacturaElectronica" class="form-check-input" />
                            <label asp-for="FacturaElectronica" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="s4-checkout-section">
                    <div class="s4-checkout-section-title">
                        <i class="fa fa-phone-alt"></i>
                        <div>
                            <span>Paso 2</span>
                            <h2>Contacto</h2>
                        </div>
                    </div>

                    <div class="s4-checkout-field-grid">
                        <div class="form-group">
                            <label asp-for="Telefono"></label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Telefono2"></label>
                            <input asp-for="Telefono2" class="form-control" />
                            <span asp-validation-for="Telefono2" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="s4-checkout-section">
                    <div class="s4-checkout-section-title">
                        <i class="fa fa-truck"></i>
                        <div>
                            <span>Paso 3</span>
                            <h2>Entrega</h2>
                        </div>
                    </div>

                    <div class="s4-checkout-field-grid">
                        <div class="form-group">
                            <label asp-for="Pais"></label>
                            <select asp-for="Pais" class="form-control">
                                <option value="Costa Rica">Costa Rica</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Método de entrega</label>
                            <input class="form-control" value="Envío a domicilio" readonly />
                            <input asp-for="TipoEntrega" type="hidden" value="Envío a domicilio" />
                        </div>
                    </div>

                    <div class="s4-checkout-field-grid s4-checkout-field-grid--three">
                        <div class="form-group">
                            <label asp-for="Provincia"></label>
                            <select asp-for="Provincia" id="provincia" class="form-control">
                                <option value="">Elige una opción...</option>
                            </select>
                            <span asp-validation-for="Provincia" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Canton"></label>
                            <select asp-for="Canton" id="canton" class="form-control" disabled>
                                <option value="">Seleccione una opción</option>
                            </select>
                            <span asp-validation-for="Canton" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Distrito"></label>
                            <select asp-for="Distrito" id="distrito" class="form-control" disabled>
                                <option value="">Seleccione una opción</option>
                            </select>
                            <span asp-validation-for="Distrito" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="DireccionDetalle"></label>
                        <input asp-for="DireccionDetalle" class="form-control" placeholder="Dirección escrita o señas" />
                        <span asp-validation-for="DireccionDetalle" class="text-danger"></span>
                    </div>
                </div>

                <div class="s4-checkout-section">
                    <div class="s4-checkout-section-title">
                        <i class="fa fa-clipboard-list"></i>
                        <div>
                            <span>Paso 4</span>
                            <h2>Notas del pedido</h2>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Observaciones"></label>
                        <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger"></span>
                    </div>
                </div>

                <div class="s4-checkout-actions">
                    <a asp-controller="Cart" asp-action="Index" class="btn s4-checkout-secondary">
                        <i class="fa fa-arrow-left mr-1"></i>Volver al carrito
                    </a>
                    <button type="submit" class="btn btn-primary s4-checkout-submit">
                        <i class="fa fa-check-circle mr-1"></i>Finalizar compra
                    </button>
                </div>
            </form>

            <aside class="s4-checkout-summary" aria-label="Resumen del pedido">
                <div class="s4-checkout-summary__header">
                    <div>
                        <span>Resumen</span>
                        <h2>Tu pedido</h2>
                    </div>
                    <i class="fa fa-shopping-basket"></i>
                </div>

                <div class="s4-checkout-summary__items">
                    @foreach (var item in Model.Cart.Items)
                    {
                        <div class="s4-checkout-summary-row">
                            <span>@item.Nombre <small>x @item.Cantidad</small></span>
                            <strong>₡@item.Subtotal.ToString("N2")</strong>
                        </div>
                    }
                </div>

                <div class="s4-checkout-summary-total">
                    <div class="s4-checkout-summary-row">
                        <span>Total</span>
                        <strong>₡@Model.Cart.Subtotal.ToString("N2")</strong>
                    </div>
                </div>

                <p class="s4-checkout-summary__footnote">
                    Revisa los datos antes de finalizar. El pedido se procesará con la información registrada aquí.
                </p>
            </aside>
        </div>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/checkout.js"></script>
}
