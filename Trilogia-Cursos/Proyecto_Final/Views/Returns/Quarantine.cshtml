@model IEnumerable<Proyecto_Final.Models.Admin.ReturnListItemViewModel>
@{
    ViewData["Title"] = "Cuarentena";
    var buscar = ViewBag.Buscar as string;
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4 backoffice-page">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header">
                <h2 class="mb-2">Productos en cuarentena</h2>
                <p class="mb-0">Mercadería devuelta retenida para evitar su reventa. Libérala para reintegrarla al inventario o descártala.</p>
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-filter-bar">
                <form asp-action="Quarantine" method="get" class="form-inline">
                    <input type="text" name="buscar" value="@buscar" class="form-control mr-2 mb-2" placeholder="Producto o motivo" />
                    <button type="submit" class="btn btn-primary mr-2 mb-2"><i class="fa fa-search mr-2"></i>Buscar</button>
                    <a asp-action="Quarantine" class="btn btn-outline-secondary mb-2"><i class="fa fa-eraser mr-2"></i>Limpiar</a>
                </form>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">En cuarentena</h5>
                    <span class="text-muted">Total: @(Model?.Count() ?? 0)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="thead-light">
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cant.</th>
                                <th>Motivo</th>
                                <th>Registrado por</th>
                                <th>Fecha</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">No hay productos en cuarentena.</td></tr>
                            }
                            else
                            {
                                @foreach (var d in Model)
                                {
                                    <tr>
                                        <td class="font-weight-bold">@d.ProductoNombre</td>
                                        <td class="text-center">@d.Cantidad</td>
                                        <td>@d.Motivo</td>
                                        <td>@d.RegistradoPorNombre</td>
                                        <td>@d.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-center">
                                            <form asp-action="Release" method="post" class="d-inline"
                                                  data-s3-confirm="¿Liberar y reintegrar @d.Cantidad unidad(es) al inventario?"
                                                  data-s3-confirm-title="Liberar de cuarentena"
                                                  data-s3-confirm-type="warning"
                                                  data-s3-confirm-ok="Sí, liberar"
                                                  data-s3-confirm-cancel="Cancelar">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="devolucionId" value="@d.DevolucionId" />
                                                <button type="submit" class="btn btn-sm btn-outline-success mb-1"><i class="fa fa-check mr-1"></i>Liberar</button>
                                            </form>
                                            <form asp-action="Discard" method="post" class="d-inline"
                                                  data-s3-confirm="¿Descartar definitivamente? No se reintegrará al inventario."
                                                  data-s3-confirm-title="Descartar producto"
                                                  data-s3-confirm-type="danger"
                                                  data-s3-confirm-ok="Sí, descartar"
                                                  data-s3-confirm-cancel="Cancelar">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="devolucionId" value="@d.DevolucionId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger mb-1"><i class="fa fa-trash mr-1"></i>Descartar</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
