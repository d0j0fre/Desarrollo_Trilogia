@model IEnumerable<Proyecto_Final.Models.Admin.RoleListItemViewModel>
@{
    ViewData["Title"] = "Roles";
    var buscar = ViewBag.Buscar as string;
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">Roles de usuario</h2>
                    <p class="text-muted mb-0">Crear, editar, activar e inactivar roles del sistema.</p>
                </div>
                <a asp-controller="Roles" asp-action="Create" class="btn btn-primary">
                    + Nuevo rol
                </a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 mb-3">
        <div class="col-12">
            <form asp-controller="Roles" asp-action="Index" method="get" class="d-flex" style="gap:8px;">
                <input type="text" name="buscar" value="@buscar"
                       class="form-control" placeholder="Buscar por nombre o descripción..." />
                <button type="submit" class="btn btn-dark">Buscar</button>
                @if (!string.IsNullOrWhiteSpace(buscar))
                {
                    <a asp-controller="Roles" asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                }
            </form>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>ID</th>
                                <th>Rol</th>
                                <th>Descripción</th>
                                <th>Usuarios</th>
                                <th>Fecha creación</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        @if (!string.IsNullOrWhiteSpace(buscar))
                                        {
                                            <span>No se encontraron roles para "<strong>@buscar</strong>".</span>
                                        }
                                        else
                                        {
                                            <span>No hay roles registrados.</span>
                                        }
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.PerfilId</td>
                                        <td class="font-weight-bold">
                                            @item.Nombre
                                            @if (item.EsRolBase)
                                            {
                                                <span class="badge badge-info ml-1">Base</span>
                                            }
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Descripcion) ? "Sin descripción" : item.Descripcion)</td>
                                        <td>
                                            <span class="badge badge-light">@item.TotalUsuarios usuario(s)</span>
                                        </td>
                                        <td>@item.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            @if (item.Activo)
                                            {
                                                <span class="badge badge-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">Inactivo</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="admin-actions">
                                                <a asp-controller="Roles" asp-action="Edit"
                                                   asp-route-id="@item.PerfilId" class="btn btn-sm btn-primary">Editar</a>

                                                @if (item.BloqueaInactivacion && item.Activo)
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled>
                                                        Protegido
                                                    </button>
                                                }
                                                else
                                                {
                                                    <form asp-controller="Roles" asp-action="ToggleStatus" method="post" class="mb-0"
                                                          onsubmit="return confirm('¿Desea cambiar el estado de este rol?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="perfilId" value="@item.PerfilId" />
                                                        <input type="hidden" name="buscar" value="@buscar" />
                                                        <button type="submit" class="btn btn-sm @(item.Activo ? "btn-danger" : "btn-success")">
                                                            @(item.Activo ? "Inactivar" : "Activar")
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
