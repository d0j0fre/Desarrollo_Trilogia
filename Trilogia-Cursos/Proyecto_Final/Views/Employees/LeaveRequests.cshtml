@model IEnumerable<Proyecto_Final.Models.Admin.EmployeeLeaveRequestViewModel>
@{
    ViewData["Title"] = "Solicitudes de empleados";
    var estado = ViewBag.Estado as string;
}

@section Styles {
    <link href="~/css/sprint3-employees.css" rel="stylesheet" />
}

<div class="container-fluid s3-page-shell employee-page py-4">
    <div class="employee-title-row mb-4">
        <div>
            <span class="s3-eyebrow"><i class="fa fa-calendar-check"></i> Días libres</span>
            <h1>Solicitudes de empleados</h1>
            <p>Revisá, aprobá o rechazá solicitudes con o sin goce salarial.</p>
        </div>
        <a asp-controller="Employees" asp-action="Index" class="btn btn-outline-dark"><i class="fa fa-arrow-left mr-1"></i>Empleados</a>
    </div>

    <form asp-controller="Employees" asp-action="LeaveRequests" method="get" class="employee-filter mb-4">
        <select name="estado" class="form-control">
            <option value="">Todos los estados</option>
            <option value="Pendiente" selected="@(estado == "Pendiente")">Pendientes</option>
            <option value="Aprobada" selected="@(estado == "Aprobada")">Aprobadas</option>
            <option value="Rechazada" selected="@(estado == "Rechazada")">Rechazadas</option>
            <option value="Cancelada" selected="@(estado == "Cancelada")">Canceladas</option>
        </select>
        <button type="submit" class="btn btn-dark"><i class="fa fa-filter mr-1"></i>Filtrar</button>
    </form>

    <div class="employee-card">
        <div class="table-responsive">
            <table class="table table-hover mb-0 employee-table">
                <thead>
                    <tr>
                        <th>Empleado</th>
                        <th>Fechas</th>
                        <th>Tipo</th>
                        <th>Motivo</th>
                        <th>Estado</th>
                        <th>Resolver</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">No hay solicitudes para mostrar.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.NombreCompleto</strong>
                                    <span class="d-block text-muted">@item.Puesto</span>
                                </td>
                                <td>
                                    @item.FechaInicio.ToString("dd/MM/yyyy") - @item.FechaFin.ToString("dd/MM/yyyy")
                                    <span class="d-block text-muted">@item.CantidadDias día(s)</span>
                                </td>
                                <td>@item.TipoSolicitud</td>
                                <td style="max-width: 280px;">@item.Motivo</td>
                                <td>
                                    <span class="badge badge-light">@item.Estado</span>
                                    @if (!string.IsNullOrWhiteSpace(item.RespuestaAdmin))
                                    {
                                        <small class="d-block text-muted mt-1">@item.RespuestaAdmin</small>
                                    }
                                </td>
                                <td>
                                    <form asp-controller="Employees" asp-action="UpdateLeaveRequest" method="post" class="employee-decision-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="SolicitudId" value="@item.SolicitudId" />
                                        <input type="hidden" name="estadoFiltro" value="@estado" />
                                        <select name="Estado" class="form-control form-control-sm">
                                            <option selected="@(item.Estado == "Pendiente")">Pendiente</option>
                                            <option selected="@(item.Estado == "Aprobada")">Aprobada</option>
                                            <option selected="@(item.Estado == "Rechazada")">Rechazada</option>
                                            <option selected="@(item.Estado == "Cancelada")">Cancelada</option>
                                        </select>
                                        <input type="text" name="RespuestaAdmin" class="form-control form-control-sm" placeholder="Respuesta u observación" value="@item.RespuestaAdmin" />
                                        <button type="submit" class="btn btn-sm btn-primary">Guardar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
