@model Proyecto_Final.Models.Admin.ExpensesIndexViewModel
@{
    ViewData["Title"] = "Gastos operativos";
    var meses = new[] { "", "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre" };
    string EjecClase(decimal? p) => !p.HasValue ? "secondary" : p >= 100 ? "danger" : p >= 80 ? "warning" : "success";
}

@section Styles {
    <link href="~/css/custom-theme.css" rel="stylesheet" />
    <style>
        .kpi-card { border-radius: 12px; border: 1px solid #eee; }
        .kpi-value { font-size: 1.5rem; font-weight: 700; }
        .prog { height: 8px; background: #eee; border-radius: 6px; overflow: hidden; }
        .prog > span { display: block; height: 100%; border-radius: 6px; }
    </style>
}

<div class="container-fluid pt-4 backoffice-page">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="admin-page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div>
                    <h2 class="mb-2">Gastos operativos</h2>
                    <p>Registro de gastos diarios y su afectación a las cuentas presupuestarias (CU-222).</p>
                </div>
                <a asp-controller="Expenses" asp-action="Accounts" class="btn btn-outline-primary mt-3 mt-md-0">
                    <i class="fa fa-wallet mr-1"></i>Cuentas presupuestarias
                </a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-3">
        <div class="col-12">
            <div class="admin-card">
                <form asp-controller="Expenses" asp-action="Index" method="get" class="form-row align-items-end">
                    <div class="form-group col-md-3">
                        <label>Año</label>
                        <input type="number" name="anio" value="@Model.Anio" min="2000" max="2100" class="form-control" />
                    </div>
                    <div class="form-group col-md-3">
                        <label>Mes</label>
                        <select name="mes" class="form-control">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(Model.Mes == i)">@meses[i]</option>
                            }
                        </select>
                    </div>
                    <div class="form-group col-md-4">
                        <label>Cuenta</label>
                        <select name="cuentaId" class="form-control">
                            <option value="">Todas</option>
                            @foreach (var c in Model.Cuentas)
                            {
                                <option value="@c.CuentaId" selected="@(Model.CuentaId == c.CuentaId)">@c.Codigo - @c.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="form-group col-md-2">
                        <button type="submit" class="btn btn-primary btn-block"><i class="fa fa-filter mr-1"></i>Filtrar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Resumen presupuestario (afectación de cuentas) -->
    <div class="row px-xl-5">
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="admin-table-wrapper kpi-card p-4 h-100">
                <div class="d-flex justify-content-between"><span class="text-muted">Presupuesto del mes</span><i class="fa fa-piggy-bank kpi-value text-primary" style="opacity:.35"></i></div>
                <div class="kpi-value">₡@Model.TotalPresupuesto.ToString("N2")</div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="admin-table-wrapper kpi-card p-4 h-100">
                <div class="d-flex justify-content-between"><span class="text-muted">Gastado</span><i class="fa fa-receipt kpi-value text-danger" style="opacity:.35"></i></div>
                <div class="kpi-value text-danger">₡@Model.TotalGastado.ToString("N2")</div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="admin-table-wrapper kpi-card p-4 h-100">
                <div class="d-flex justify-content-between"><span class="text-muted">Disponible</span><i class="fa fa-balance-scale kpi-value text-success" style="opacity:.35"></i></div>
                <div class="kpi-value @(Model.TotalDisponible < 0 ? "text-danger" : "text-success")">₡@Model.TotalDisponible.ToString("N2")</div>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-4">
        <div class="col-12">
            <div class="admin-table-wrapper">
                <div class="p-4 border-bottom"><h5 class="mb-0">Ejecución presupuestaria por cuenta — @meses[Model.Mes] @Model.Anio</h5></div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Cuenta</th>
                                <th class="text-right">Presupuesto</th>
                                <th class="text-right">Gastado</th>
                                <th class="text-right">Disponible</th>
                                <th style="min-width:180px;">Ejecución</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Resumen.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">No hay cuentas presupuestarias activas.</td></tr>
                            }
                            else
                            {
                                @foreach (var r in Model.Resumen)
                                {
                                    var clase = EjecClase(r.PorcentajeEjecucion);
                                    var ancho = (int)Math.Min(r.PorcentajeEjecucion ?? 0, 100);
                                    <tr>
                                        <td><strong>@r.Codigo</strong> · @r.Nombre</td>
                                        <td class="text-right">₡@r.PresupuestoMensual.ToString("N2")</td>
                                        <td class="text-right">₡@r.Gastado.ToString("N2")</td>
                                        <td class="text-right @(r.Disponible < 0 ? "text-danger font-weight-bold" : "")">₡@r.Disponible.ToString("N2")</td>
                                        <td>
                                            <span class="admin-badge-soft @clase">@(r.PorcentajeEjecucion?.ToString("N1") ?? "—")%</span>
                                            <div class="prog mt-1"><span class="bg-@clase" style="width:@(ancho)%"></span></div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row px-xl-5 pb-5">
        <div class="col-lg-4 pb-3">
            <div class="admin-card h-100">
                <h5 class="mb-3">Registrar gasto</h5>
                <form asp-controller="Expenses" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="anio" value="@Model.Anio" />
                    <input type="hidden" name="mes" value="@Model.Mes" />
                    <input type="hidden" name="cuentaFiltro" value="@Model.CuentaId" />

                    <div class="form-group">
                        <label>Cuenta presupuestaria</label>
                        <select name="CuentaId" class="form-control" required>
                            <option value="">— Seleccione —</option>
                            @foreach (var c in Model.Cuentas)
                            {
                                <option value="@c.CuentaId">@c.Codigo - @c.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Fecha</label>
                        <input type="date" name="Fecha" value="@Model.Nuevo.Fecha.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Monto (₡)</label>
                        <input type="number" name="Monto" step="0.01" min="0.01" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Concepto</label>
                        <input type="text" name="Concepto" class="form-control" maxlength="200" required placeholder="Ej. Combustible reparto ruta norte" />
                    </div>
                    <div class="form-group">
                        <label>Proveedor</label>
                        <input type="text" name="Proveedor" class="form-control" maxlength="150" placeholder="Opcional" />
                    </div>
                    <div class="form-group">
                        <label>N.º de comprobante</label>
                        <input type="text" name="Comprobante" class="form-control" maxlength="60" placeholder="Opcional" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-block py-2"><i class="fa fa-save mr-1"></i>Registrar gasto</button>
                </form>
            </div>
        </div>

        <div class="col-lg-8 pb-3">
            <div class="admin-table-wrapper h-100">
                <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Gastos del período</h5>
                    <span class="badge badge-dark">@Model.Gastos.Count gasto(s)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Cuenta</th>
                                <th>Concepto</th>
                                <th>Proveedor</th>
                                <th class="text-right">Monto</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Gastos.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">No hay gastos registrados en este período.</td></tr>
                            }
                            else
                            {
                                @foreach (var g in Model.Gastos)
                                {
                                    <tr>
                                        <td>@g.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td><span class="badge badge-light">@g.CuentaCodigo</span> @g.CuentaNombre</td>
                                        <td>
                                            @g.Concepto
                                            @if (!string.IsNullOrWhiteSpace(g.Comprobante))
                                            {
                                                <small class="text-muted d-block">Comp.: @g.Comprobante</small>
                                            }
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(g.Proveedor) ? "—" : g.Proveedor)</td>
                                        <td class="text-right font-weight-bold">₡@g.Monto.ToString("N2")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
