@model Proyecto_Final.Models.Admin.ExpensesDashboardViewModel
@{ ViewData["Title"] = "Gastos operativos"; ViewBag.Departments = Model.Departments; ViewBag.Categories = Model.Categories; string Color(string s)=>s=="Excedido"?"danger":s=="Crítico"?"danger":s=="Advertencia"?"warning":"success"; }
<div class="container-fluid py-4 px-xl-5"><div class="d-flex flex-wrap justify-content-between align-items-center mb-3"><div><h2>Gastos operativos</h2><p class="text-muted">Registro, aprobación, pago y afectación presupuestaria (CU-222).</p></div><div><a asp-controller="Budgets" asp-action="Index" class="btn btn-outline-primary">Presupuestos</a> <a asp-controller="BudgetComparison" asp-action="Index" class="btn btn-primary">Presupuesto vs. real</a></div></div>
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
<div class="row mb-3"><div class="col"><div class="card p-3"><small>Registrado</small><strong>₡@Model.RegisteredTotal.ToString("N2")</strong></div></div><div class="col"><div class="card p-3"><small>Aprobado</small><strong>₡@Model.ApprovedTotal.ToString("N2")</strong></div></div><div class="col"><div class="card p-3"><small>Pagado</small><strong>₡@Model.PaidTotal.ToString("N2")</strong></div></div><div class="col"><div class="card p-3"><small>Pendiente</small><strong>₡@Model.PendingTotal.ToString("N2")</strong></div></div><div class="col"><div class="card p-3"><small>Disponible</small><strong class="@(Model.AvailableBudget < 0 ? "text-danger" : "text-success")">₡@Model.AvailableBudget.ToString("N2")</strong></div></div></div>
<div class="card mb-3"><div class="card-header">Registrar gasto</div><div class="card-body"><form asp-action="Create" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()<partial name="_OperatingForm" model="Model.NewExpense"/><button class="btn btn-primary">Registrar con token idempotente</button></form></div></div>
<div class="card mb-3"><div class="card-body"><form method="get" class="form-row"><div class="col-md-3 mb-2"><input name="Search" value="@Model.Filter.Search" class="form-control" placeholder="Documento, proveedor o descripción"/></div><div class="col-md-2 mb-2"><input type="date" name="From" value="@Model.Filter.From?.ToString("yyyy-MM-dd")" class="form-control"/></div><div class="col-md-2 mb-2"><input type="date" name="To" value="@Model.Filter.To?.ToString("yyyy-MM-dd")" class="form-control"/></div><div class="col-md-2 mb-2"><select name="DepartmentId" class="form-control"><option value="">Departamento</option>@foreach(var x in Model.Departments){<option value="@x.Id">@x.Name</option>}</select></div><div class="col-md-2 mb-2"><select name="CategoryId" class="form-control"><option value="">Categoría</option>@foreach(var x in Model.Categories){<option value="@x.Id">@x.Name</option>}</select></div><div class="col-md-2 mb-2"><select name="Status" class="form-control"><option value="">Todos los estados</option><option>Registrado</option><option>Aprobado</option><option>Rechazado</option><option>Pagado</option><option>Anulado</option></select></div><div class="col-md-2 mb-2"><button class="btn btn-dark btn-block">Filtrar</button></div></form></div></div>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Fecha / documento</th><th>Departamento</th><th>Descripción</th><th>Total</th><th>Estado</th><th>Impacto</th><th></th></tr></thead><tbody>@if(!Model.Expenses.Items.Any()){<tr><td colspan="7" class="text-center py-4 text-muted">No hay gastos.</td></tr>}@foreach(var e in Model.Expenses.Items){<tr><td>@e.ExpenseDate.ToString("dd/MM/yyyy")<small class="d-block">@e.DocumentNumber</small></td><td>@e.DepartmentName<small class="d-block text-muted">@e.CategoryName</small></td><td>@e.Description<small class="d-block text-muted">@(e.SupplierName ?? "Sin proveedor")</small></td><td class="font-weight-bold">₡@e.Total.ToString("N2")</td><td>@e.Status</td><td><span class="badge badge-@Color(e.ConsumptionLevel)">@e.ConsumptionLevel · @e.ExecutionPercent.ToString("N1")%</span></td><td><a asp-action="Details" asp-route-id="@e.ExpenseId" class="btn btn-sm btn-outline-primary">Ver</a></td></tr>}</tbody></table></div><div class="card-footer d-flex justify-content-between"><span>@Model.Expenses.Total gasto(s)</span><span>@if(Model.Expenses.Page>1){<a asp-route-Page="@(Model.Expenses.Page-1)" asp-route-Search="@Model.Filter.Search" asp-route-From="@Model.Filter.From?.ToString("yyyy-MM-dd")" asp-route-To="@Model.Filter.To?.ToString("yyyy-MM-dd")" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-CategoryId="@Model.Filter.CategoryId" asp-route-Status="@Model.Filter.Status" class="btn btn-sm btn-outline-secondary">Anterior</a>} @if(Model.Expenses.Page<Model.Expenses.TotalPages){<a asp-route-Page="@(Model.Expenses.Page+1)" asp-route-Search="@Model.Filter.Search" asp-route-From="@Model.Filter.From?.ToString("yyyy-MM-dd")" asp-route-To="@Model.Filter.To?.ToString("yyyy-MM-dd")" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-CategoryId="@Model.Filter.CategoryId" asp-route-Status="@Model.Filter.Status" class="btn btn-sm btn-outline-secondary">Siguiente</a>}</span></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
