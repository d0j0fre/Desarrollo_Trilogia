@model Proyecto_Final.Models.Admin.OperatingExpenseFormViewModel
@using Proyecto_Final.Models.Admin
@{ var departments = ViewBag.Departments as IReadOnlyList<SelectOptionViewModel> ?? Array.Empty<SelectOptionViewModel>(); var categories = ViewBag.Categories as IReadOnlyList<SelectOptionViewModel> ?? Array.Empty<SelectOptionViewModel>(); }
<input asp-for="ExpenseId" type="hidden"/><input asp-for="OperationToken" type="hidden"/>
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="form-row"><div class="form-group col-md-4"><label asp-for="ExpenseDate">Fecha</label><input asp-for="ExpenseDate" class="form-control"/><span asp-validation-for="ExpenseDate" class="text-danger"></span></div><div class="form-group col-md-4"><label asp-for="DepartmentId">Departamento</label><select asp-for="DepartmentId" class="form-control"><option value="">Seleccione</option>@foreach(var x in departments){<option value="@x.Id">@x.Name</option>}</select></div><div class="form-group col-md-4"><label asp-for="CategoryId">Categoría</label><select asp-for="CategoryId" class="form-control"><option value="">Seleccione</option>@foreach(var x in categories){<option value="@x.Id">@x.Name</option>}</select></div></div>
<div class="form-row"><div class="form-group col-md-6"><label asp-for="SupplierName">Proveedor</label><input asp-for="SupplierName" class="form-control"/></div><div class="form-group col-md-3"><label asp-for="DocumentNumber">N.º documento</label><input asp-for="DocumentNumber" class="form-control"/></div><div class="form-group col-md-3"><label asp-for="DocumentType">Tipo</label><select asp-for="DocumentType" class="form-control"><option>Factura</option><option>Recibo</option><option>Nota de débito</option><option>Otro</option></select></div></div>
<div class="form-group"><label asp-for="Description">Descripción</label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
<div class="form-row"><div class="form-group col-md-3"><label asp-for="Subtotal">Subtotal</label><input asp-for="Subtotal" type="number" step="0.01" min="0.01" class="form-control"/></div><div class="form-group col-md-3"><label asp-for="Tax">Impuesto</label><input asp-for="Tax" type="number" step="0.01" min="0" class="form-control"/></div><div class="form-group col-md-3"><label asp-for="PaymentMethod">Pago</label><select asp-for="PaymentMethod" class="form-control"><option>Transferencia</option><option>Tarjeta</option><option>Efectivo</option><option>Crédito</option></select></div><div class="form-group col-md-3">@if(Model.ExpenseId == 0){<label asp-for="Receipt">Comprobante privado</label><input asp-for="Receipt" type="file" accept=".pdf,.jpg,.jpeg,.png" class="form-control-file"/>}else{<label>Comprobante</label><p class="form-control-plaintext text-muted">Se conserva el archivo original.</p>}</div></div>
