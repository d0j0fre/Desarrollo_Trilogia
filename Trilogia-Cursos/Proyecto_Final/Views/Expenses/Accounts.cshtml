@model Proyecto_Final.Models.Admin.AccountsViewModel
@{ ViewData["Title"] = "Cuentas presupuestarias legadas"; }
<div class="container-fluid py-4 px-xl-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div><h2>Cuentas presupuestarias legadas</h2><p class="text-muted mb-0">Consulta temporal del modelo mensual anterior a CU-221. El modelo autoritativo nuevo es el presupuesto anual.</p></div>
        <div><a asp-controller="Budgets" asp-action="Index" class="btn btn-primary">Ir a presupuestos anuales</a> <a asp-action="Index" class="btn btn-outline-secondary">Volver a gastos</a></div>
    </div>
    <div class="alert alert-warning"><strong>Sólo lectura.</strong> No cree ni modifique cuentas mensuales; la migración 0010 conserva estos registros por compatibilidad.</div>
    <div class="card"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Código</th><th>Nombre</th><th>Descripción</th><th class="text-right">Presupuesto mensual</th><th>Estado</th></tr></thead><tbody>
    @if (!Model.Cuentas.Any()) { <tr><td colspan="5" class="text-center py-4 text-muted">No hay cuentas legadas.</td></tr> }
    @foreach (var account in Model.Cuentas) { <tr><td><strong>@account.Codigo</strong></td><td>@account.Nombre</td><td>@(account.Descripcion ?? "—")</td><td class="text-right">₡@account.PresupuestoMensual.ToString("N2")</td><td>@(account.Activo ? "Activa" : "Inactiva")</td></tr> }
    </tbody></table></div></div>
</div>
