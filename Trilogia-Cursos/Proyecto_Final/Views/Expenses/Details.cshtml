@model Proyecto_Final.Models.Admin.OperatingExpenseDetailsViewModel
@{ ViewData["Title"] = $"Gasto {Model.Expense.ExpenseId}"; }
<div class="container py-4"><div class="d-flex justify-content-between align-items-center mb-3"><div><h2>Gasto #@Model.Expense.ExpenseId</h2><p class="text-muted">@Model.Expense.DepartmentName · @Model.Expense.CategoryName</p></div><div><a asp-action="Index" class="btn btn-outline-secondary">Volver</a> @if(Model.Expense.Status=="Registrado"){<a asp-action="Edit" asp-route-id="@Model.Expense.ExpenseId" class="btn btn-outline-primary">Editar</a>}</div></div>
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
<div class="row"><div class="col-lg-7"><div class="card mb-3"><div class="card-body"><dl class="row"><dt class="col-sm-4">Fecha</dt><dd class="col-sm-8">@Model.Expense.ExpenseDate.ToString("dd/MM/yyyy")</dd><dt class="col-sm-4">Documento</dt><dd class="col-sm-8">@Model.DocumentType @Model.Expense.DocumentNumber</dd><dt class="col-sm-4">Proveedor</dt><dd class="col-sm-8">@(Model.Expense.SupplierName ?? "—")</dd><dt class="col-sm-4">Descripción</dt><dd class="col-sm-8">@Model.Expense.Description</dd><dt class="col-sm-4">Subtotal / impuesto</dt><dd class="col-sm-8">₡@Model.Expense.Subtotal.ToString("N2") / ₡@Model.Expense.Tax.ToString("N2")</dd><dt class="col-sm-4">Total</dt><dd class="col-sm-8 h4">₡@Model.Expense.Total.ToString("N2")</dd><dt class="col-sm-4">Pago</dt><dd class="col-sm-8">@Model.PaymentMethod</dd><dt class="col-sm-4">Estado</dt><dd class="col-sm-8"><strong>@Model.Expense.Status</strong></dd></dl>@if(Model.Expense.HasReceipt){<a asp-action="Receipt" asp-route-id="@Model.Expense.ExpenseId" class="btn btn-outline-primary"><i class="fa fa-lock"></i> Descargar comprobante</a>}</div></div></div>
<div class="col-lg-5"><div class="card mb-3"><div class="card-header">Impacto presupuestario</div><div class="card-body"><p>Presupuesto: <strong>₡@Model.Expense.BudgetAmount.ToString("N2")</strong></p><p>Real: <strong>₡@Model.Expense.RealSpent.ToString("N2")</strong></p><p>Comprometido: <strong>₡@Model.Expense.CommittedSpent.ToString("N2")</strong></p><p>Nivel: <strong>@Model.Expense.ConsumptionLevel (@Model.Expense.ExecutionPercent.ToString("N2")%)</strong></p></div></div>
<div class="card"><div class="card-header">Acciones</div><div class="card-body">@if(Model.Expense.Status=="Registrado"){<form asp-action="Approve" method="post" class="mb-2">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Expense.ExpenseId"/><div class="custom-control custom-checkbox mb-2"><input type="checkbox" name="overrideBudget" value="true" class="custom-control-input" id="override"/><label class="custom-control-label" for="override">Autorizar exceso (requiere permiso)</label></div><button class="btn btn-success btn-block">Aprobar</button></form><form asp-action="Reject" method="post"><input type="hidden" name="id" value="@Model.Expense.ExpenseId"/>@Html.AntiForgeryToken()<input name="reason" class="form-control mb-2" required maxlength="500" placeholder="Motivo"/><button class="btn btn-outline-danger btn-block">Rechazar</button></form>}@if(Model.Expense.Status=="Aprobado"){<form asp-action="Pay" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Expense.ExpenseId"/><button class="btn btn-primary btn-block">Marcar pagado</button></form>}@if(Model.Expense.Status!="Pagado" && Model.Expense.Status!="Anulado"){<hr/><form asp-action="Cancel" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Expense.ExpenseId"/><input name="reason" class="form-control mb-2" required maxlength="500" placeholder="Motivo de anulación"/><button class="btn btn-outline-dark btn-block">Anular</button></form>}</div></div></div></div>
<div class="card"><div class="card-header">Auditoría</div><ul class="list-group list-group-flush">@foreach(var a in Model.Audit){<li class="list-group-item"><strong>@a.Action</strong> · @a.UserName <small class="d-block">@a.CreatedUtc.ToString("dd/MM/yyyy HH:mm") UTC</small><span>@a.Detail</span></li>}</ul></div></div>
