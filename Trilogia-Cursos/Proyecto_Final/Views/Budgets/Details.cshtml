@model Proyecto_Final.Models.Admin.BudgetDetailsViewModel
@{ ViewData["Title"] = $"Presupuesto {Model.Budget.Year}"; var names = System.Globalization.CultureInfo.GetCultureInfo("es-CR").DateTimeFormat.MonthNames; }
<div class="container-fluid py-4 px-xl-5"><div class="d-flex flex-wrap justify-content-between align-items-center mb-3"><div><h2>@Model.Budget.DepartmentName · @Model.Budget.Year</h2><p class="text-muted">₡@Model.Budget.AnnualAmount.ToString("N2") · <strong>@Model.Budget.Status</strong></p></div><a asp-action="Index" class="btn btn-outline-secondary">Volver</a></div>
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
<div class="card mb-3"><div class="card-body d-flex flex-wrap align-items-center">
@if(Model.Budget.Status == "Borrador" || Model.Budget.Status == "Rechazado"){<form asp-action="Submit" method="post" class="mr-2 mb-2">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Budget.BudgetId"/><button class="btn btn-primary">Presentar</button></form>}
@if(Model.Budget.Status == "Presentado"){<form asp-action="Approve" method="post" class="mr-2 mb-2">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Budget.BudgetId"/><button class="btn btn-success">Aprobar</button></form><form asp-action="Reject" method="post" class="form-inline mr-2 mb-2">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Budget.BudgetId"/><input name="reason" class="form-control mr-1" maxlength="500" required placeholder="Motivo de rechazo"/><button class="btn btn-danger">Rechazar</button></form>}
@if(Model.Budget.Status == "Aprobado"){<form asp-action="Close" method="post" class="mr-2 mb-2">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Budget.BudgetId"/><button class="btn btn-outline-dark">Cerrar</button></form>}
<form asp-action="Copy" method="post" class="form-inline mb-2">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Budget.BudgetId"/><input type="number" name="targetYear" value="@(Model.Budget.Year + 1)" min="2000" max="2100" class="form-control mr-1"/><button class="btn btn-outline-primary">Copiar a otro año</button></form></div></div>
<div class="row"><div class="col-lg-8"><div class="card"><div class="card-header">Distribución mensual</div><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Categoría</th><th>Mes</th><th class="text-right">Monto</th><th>Notas</th><th></th></tr></thead><tbody>@foreach(var d in Model.Details){<tr><td>@d.CategoryName</td><td>@names[d.Month-1]</td><td class="text-right">₡@d.AllocatedAmount.ToString("N2")</td><td>@(d.Notes ?? "—")</td><td>@if(Model.CanEdit){<form asp-action="SaveDetail" method="post" class="form-inline flex-nowrap">@Html.AntiForgeryToken()<input type="hidden" name="BudgetId" value="@Model.Budget.BudgetId"/><input type="hidden" name="BudgetDetailId" value="@d.BudgetDetailId"/><input type="hidden" name="CategoryId" value="@d.CategoryId"/><input type="hidden" name="Month" value="@d.Month"/><input type="number" name="AllocatedAmount" value="@d.AllocatedAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)" min="0" step="0.01" class="form-control form-control-sm mr-1" style="width:105px" aria-label="Nuevo monto"/><input type="hidden" name="Notes" value="@d.Notes"/><button class="btn btn-sm btn-outline-primary">Actualizar</button></form>}</td></tr>}</tbody><tfoot><tr><th colspan="2">Total distribuido</th><th class="text-right">₡@Model.Details.Sum(x=>x.AllocatedAmount).ToString("N2")</th><th colspan="2"></th></tr></tfoot></table></div></div></div>
<div class="col-lg-4">@if(Model.CanEdit){<div class="card mb-3"><div class="card-header">Editar borrador</div><div class="card-body"><form asp-action="UpdateDraft" method="post">@Html.AntiForgeryToken()<input type="hidden" name="BudgetId" value="@Model.Budget.BudgetId"/><div class="form-row"><div class="col"><label>Año</label><input type="number" name="Year" value="@Model.Budget.Year" min="2000" max="2100" class="form-control" required/></div><div class="col"><label>Monto anual</label><input type="number" name="AnnualAmount" value="@Model.Budget.AnnualAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)" min="0.01" step="0.01" class="form-control" required/></div></div><label class="mt-2">Notas</label><textarea name="Notes" class="form-control mb-2" maxlength="800">@Model.Budget.Notes</textarea><button class="btn btn-outline-primary btn-block">Actualizar encabezado</button></form></div></div><div class="card mb-3"><div class="card-header">Agregar o editar línea</div><div class="card-body"><form asp-action="SaveDetail" method="post">@Html.AntiForgeryToken()<input type="hidden" name="BudgetId" value="@Model.Budget.BudgetId"/><div class="form-group"><select name="CategoryId" class="form-control" required><option value="">Categoría</option>@foreach(var c in Model.Categories){<option value="@c.Id">@c.Name</option>}</select></div><div class="form-row"><div class="col"><input type="number" name="Month" min="1" max="12" class="form-control" placeholder="Mes" required/></div><div class="col"><input type="number" name="AllocatedAmount" min="0" step="0.01" class="form-control" placeholder="Monto" required/></div></div><input name="Notes" maxlength="300" class="form-control my-2" placeholder="Notas"/><button class="btn btn-primary btn-block">Guardar línea</button></form><hr/><form asp-action="Distribute" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Budget.BudgetId"/><select name="categoryId" class="form-control mb-2" required>@foreach(var c in Model.Categories){<option value="@c.Id">@c.Name</option>}</select><button class="btn btn-outline-primary btn-block">Distribuir monto anual</button></form></div></div>}
<div class="card"><div class="card-header">Auditoría</div><ul class="list-group list-group-flush">@foreach(var a in Model.Audit){<li class="list-group-item"><strong>@a.Action</strong><small class="d-block">@a.UserName · @a.CreatedUtc.ToString("dd/MM/yyyy HH:mm") UTC</small><span>@a.Detail</span></li>}</ul></div></div></div></div>
