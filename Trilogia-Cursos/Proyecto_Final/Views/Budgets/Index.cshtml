@model Proyecto_Final.Models.Admin.BudgetsIndexViewModel
@{ ViewData["Title"] = "Presupuestos anuales"; }
<div class="container-fluid py-4 px-xl-5"><div class="d-flex justify-content-between align-items-center mb-3"><div><h2>Presupuestos anuales</h2><p class="text-muted">Planificación por departamento, categoría y mes (CU-221).</p></div><a asp-controller="BudgetComparison" asp-action="Index" class="btn btn-outline-primary"><i class="fa fa-chart-bar"></i> Presupuesto vs. real</a></div>
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
<div class="row"><div class="col-lg-4 mb-3"><div class="card"><div class="card-header">Nuevo presupuesto</div><div class="card-body"><form asp-action="Create" method="post">@Html.AntiForgeryToken()<div class="form-group"><label>Año</label><input asp-for="NewBudget.Year" name="Year" class="form-control" min="2000" max="2100"/></div><div class="form-group"><label>Departamento</label><select asp-for="NewBudget.DepartmentId" name="DepartmentId" class="form-control"><option value="">Seleccione</option>@foreach(var x in Model.Departments){<option value="@x.Id">@x.Name</option>}</select></div><div class="form-group"><label>Categoría inicial</label><select asp-for="NewBudget.CategoryId" name="CategoryId" class="form-control"><option value="">Seleccione</option>@foreach(var x in Model.Categories){<option value="@x.Id">@x.Name</option>}</select></div><div class="form-group"><label>Monto anual (CRC)</label><input asp-for="NewBudget.AnnualAmount" name="AnnualAmount" class="form-control" type="number" step="0.01" min="0.01"/></div><div class="form-group"><label>Notas</label><textarea asp-for="NewBudget.Notes" name="Notes" class="form-control"></textarea></div><button class="btn btn-primary btn-block">Crear borrador</button></form></div></div></div>
<div class="col-lg-8"><div class="card mb-3"><div class="card-body"><form method="get" class="form-row"><div class="col-md-3"><input type="number" name="Year" value="@Model.Filter.Year" min="2000" max="2100" class="form-control" placeholder="Año"/></div><div class="col-md-4"><select name="DepartmentId" class="form-control"><option value="">Todos los departamentos</option>@foreach(var x in Model.Departments){<option value="@x.Id">@x.Name</option>}</select></div><div class="col-md-3"><select name="Status" class="form-control"><option value="">Todos los estados</option><option>Borrador</option><option>Presentado</option><option>Aprobado</option><option>Rechazado</option><option>Cerrado</option><option>Inactivo</option></select></div><div class="col-md-2"><button class="btn btn-dark btn-block">Filtrar</button></div></form></div></div>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Año</th><th>Departamento</th><th>Estado</th><th>Monto anual</th><th>Creación</th><th></th></tr></thead><tbody>@if(!Model.Budgets.Items.Any()){<tr><td colspan="6" class="text-center py-4 text-muted">No hay presupuestos.</td></tr>}@foreach(var b in Model.Budgets.Items){<tr><td>@b.Year</td><td>@b.DepartmentName</td><td><span class="badge badge-@(b.Status == "Aprobado" ? "success" : b.Status == "Rechazado" ? "danger" : "secondary")">@b.Status</span></td><td>₡@b.AnnualAmount.ToString("N2")</td><td>@b.CreatedByName<br/><small>@b.CreatedUtc.ToString("dd/MM/yyyy HH:mm") UTC</small></td><td><a asp-action="Details" asp-route-id="@b.BudgetId" class="btn btn-sm btn-outline-primary">Gestionar</a></td></tr>}</tbody></table></div><div class="card-footer d-flex justify-content-between"><span>@Model.Budgets.Total resultado(s)</span><span>@if(Model.Budgets.Page>1){<a asp-route-Page="@(Model.Budgets.Page-1)" asp-route-Year="@Model.Filter.Year" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-Status="@Model.Filter.Status" class="btn btn-sm btn-outline-secondary">Anterior</a>} @if(Model.Budgets.Page<Model.Budgets.TotalPages){<a asp-route-Page="@(Model.Budgets.Page+1)" asp-route-Year="@Model.Filter.Year" asp-route-DepartmentId="@Model.Filter.DepartmentId" asp-route-Status="@Model.Filter.Status" class="btn btn-sm btn-outline-secondary">Siguiente</a>}</span></div></div></div></div></div>
